[0.000, "o", "0m\u001b[38;5;252m Object constructors require named arguments (e.g., \u001b[0m\u001b[38;5;203;48;5;236m Point(x: 1, y: 2) \u001b[0m\u001b[38;5;252m), and getter methods use property syntax without parentheses (e.g., \u001b[0m\u001b[38;5;203;48;5;236m nums.len \u001b[0m\u001b[38;5;252m instead of \u001b[0m\u001b[38;5;203;48;5;236m nums.len() \u001b[0m\u001b[38;5;252m).\u001b[0m\r\n\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252m• \u001b[0m\u001b[38;5;252;1mMap literals:\u001b[0m\u001b[38;5;252m Empty maps cannot be defined as \u001b[0m\u001b[38;5;203;48;5;236m {} \u001b[0m\u001b[38;5;252m (which is rejected); they must be written as \u001b[0m\u001b[38;5;203;48;5;236m {:} \u001b[0m\u001b[38;5;252m to distinguish them from empty\u001b[0m\u001b[38;5;252m structures/blocks.\u001b[0m\r\n\r\n"]
