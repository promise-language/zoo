[0.000, "o", "m\u001b[38;5;252m decisions:\u001b[0m\r\n  \r\n\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252m• \u001b[0m\u001b[38;5;252;1mRust-like ownership with Go-like ease of use:\u001b[0m\u001b[38;5;252m Types like strings are move-by-default, but the compiler automatically infers borrows based on parameter declarations. There is no need to write \u001b[0m\u001b[38;5;203;48;5;236m & \u001b[0m\u001b[38;5;252m or \u001b[0m\u001b[38;5;203;48;5;236m ~ \u001b[0m\u001b[38;5;252m reference symbols at the call\u001b[0m\u001b[38;5;252m site.\u001b[0m\r\n\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252m• \u001b[0m\u001b[38;5;252;1mFailable functions and automatic error propagation:\u001b[0m\u001b[38;5;252m Functions that can fail are suffixed with a \u001b[0m\u001b[38;5;203;48;5;236m ! \u001b[0m\u001b[38;5;252m (e.g., \u001b[0m\u001b[38;5;203;48;5;236m main!() \u001b[0m\u001b[38;5;252m). Errors auto-propagate via bare function calls or \u001b[0m\u001b[38;5;203;48;5;236m ?^ \u001b[0m\u001b[38;5;252m inside failable functions, while \u001b[0m\u001b[38;5;203;48;5;236m ?! \u001b[0m\u001b[38;5;252m explicitly\u001b[0m\u001b[38;5;252m panics.\u001b[0m\r\n\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252m• \u001b[0m\u001b[38;5;252;1mConstructors and properties"]
