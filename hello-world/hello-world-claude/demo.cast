[0.037, "o", "\u001b[?25l\u001b[H\u001b[K\r\u001b[2B\u001b[48;2;55;55;55m\u001b[38;2;80;80;80m❯ \u001b[38;2;255;255;255mPromise is a brand-new statically-typed, natively-compiled programming language. Its compiler is already installed on\u001b[39m \r\u001b[1B  \u001b[38;2;255;255;255mthis machine\u001b[16Gas the `promise` command, but \u001b[47Ghe \u001b[51Ganguage is\u001b[62Gnot in your\u001b[74Gtraining da\u001b[86Ga, so first le\u001b[101Grn it:\u001b[108Grun \u001b[39m        \r\u001b[2C\u001b[1B\u001b[38;2;255;255;255m`promise --help` and `promise\u001b[33Gguide` to pick up the syntax\u001b[62Gand\u001b[66Gthe project workflow.\u001b[39m                         \r\u001b[2C\u001b[1B                                                                                    \r\u001b[2C\u001b[2B\u001b[38;2;255;255;255mWrite the classic \"hello, world\" program in Promise, build it, and run it so we can see the output.\r\u001b[2C\u001b[1B\u001b[39m                                                                                                   \r\u001b[2C\u001b[2B\u001b[38;2;255;255;255mWhen you're done, write SUMMARY.md in the current directory: a few sentences on what you built, whether it compiled \r\u001b[2C\u001b[1Band ran"]
[0.000, "o", " on the first \u001b[25Gry, the program\u001b[41Goutput, a\u001b[51Gd\u001b[53Ganything about Promis\u001b[75G that surprised yo\u001b[94G or that you\u001b[107Ghad to work\r\u001b[2C\u001b[1Bout\u001b[7G(it\u001b[11Gis\u001b[14Gnot\u001b[18Gin your training dat\u001b[39G).\u001b[39m                                                                              \r\u001b[1B\u001b[49m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mI'll\u001b[8Gstart\u001b[14Gby\u001b[17Glearning\u001b[26GPromise,\u001b[35Gthen\u001b[40Gwrite,\u001b[47Gbuild,\u001b[54Gand\u001b[58Grun\u001b[62Gthe\u001b[66Gprogram.\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m shell commands \r\u001b[2C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mI've\u001b[8Glearned\u001b[16Gthe\u001b[20Gsyntax.\u001b[28GLet\u001b[32Gme\u001b[35Gwrite\u001b[41Gthe\u001b[45Gprogram\u001b[53Gand\u001b[57Gbuild/run\u001b[67Git.\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;78;186;101m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(hello.pr)\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  \u001b[39mWrot\u001b[11G \u001b[1m3\u001b[22m lines\u001b[20Gto\u001b[23G\u001b[1mhello.pr\r\u001b[1B\u001b[22m     \u001b[38;2;248;248;242m\u001b[2m 1 \u001b[22mmain() {\u001b[39m\u001b[K\r\u001b[6C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m2\u001b[9G\u001b[22m  print_line(\"hello, world\");\r\u001b[6C\u001b[1B\u001b[2m3\u001b[9G\u001b[22m}\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2"]
