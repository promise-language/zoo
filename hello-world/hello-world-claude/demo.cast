[0.108, "o", "\u001b[?25l\u001b[H\r\u001b[1B\u001b[48;2;55;55;55m  \u001b[38;2;255;255;255mthis machine as the `promise` command, but the language is not in your training data, so first learn it: run \u001b[39m         \r\u001b[1B  \u001b[38;2;255;255;255m`promise --help` and `promise guide` to pick up the syntax\u001b[62Gand the project workflow.\u001b[39m                                 \r\u001b[2C\u001b[1B                                                                                                             \r\u001b[2C\u001b[1B                                                                                    \r\u001b[2C\u001b[1B\u001b[38;2;255;255;255mWrite the classic \"hello, world\" program in Promise, build it, and run it so we can see the output.\r\u001b[2C\u001b[2B\u001b[39m                                                                                                   \r\u001b[2C\u001b[1B\u001b[38;2;255;255;255mWhen you're done, write SUMMARY.md in the current directory: a few sentences on what you built, whether it compiled \r\u001b[2C\u001b[1Band ran on the first try, the program output, and anything about Promise that surprised you or"]
[0.000, "o", " that you had to work \r\u001b[2C\u001b[1Bout (it is not in\u001b[21Gyour training data).\u001b[39m                                                                              \r\u001b[1B\u001b[49m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[39m I'll start by learning Promise, then write, build, and run the program.\u001b[K\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m shell commands \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mI've learned the syntax.\u001b[28GLet\u001b[32Gme\u001b[35Gwrite\u001b[41Gthe\u001b[45Gprogram\u001b[53Gand\u001b[57Gbuild/run\u001b[67Git.\r\u001b[2B\u001b[38;2;78;186;101m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(hello.pr)\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  \u001b[39mWrote\u001b[12G\u001b[1m3\u001b[14G\u001b[22mlines\u001b[20Gto\u001b[23G\u001b[1mhello.pr\r\u001b[1B\u001b[22m \u001b[3G   \u001b[38;2;248;248;242m\u001b[2m 1 \u001b[22mmain() {\u001b[39m\u001b[K\r\u001b[1B     \u001b[38;2;248;248;242m\u001b[2m 2 \u001b[22m  print_line(\"hello, world\");\r\u001b[6C\u001b[1B\u001b[2m3\u001b[9G\u001b[22m}\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mCompiled and ran on the\u001b[27Gfirst\u001b[33Gtry.\u001b[38GNow\u001b[42Gthe\u001b[46Gsummary.\r\u001b[2B\u001b[38;2;153;153;153m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m"]
[0.000, "o", "(SUMMARY.md)\u001b[K\r\u001b[16C\u001b[2B\u001b[38;2;153;153;153m8\u001b[39m\u001b[36;1H\u001b[34;3H\u001b[?25h"]
[0.017, "o", "\u001b[?25l\u001b[H\u001b[48;2;55;55;55m\u001b[38;2;80;80;80m❯ \u001b[38;2;255;255;255mPromise is a brand-new statically-typed, natively-compiled programming language. Its compiler is already installed on\u001b[39m \r\u001b[30B\u001b[49m\u001b[38;2;215;119;87m✶\u001b[25G\u001b[38;2;153;153;153m7\u001b[39m\u001b[36;1H\u001b[34;3H\u001b[?25h"]
[0.045, "o", "\u001b[?25l\u001b[H\u001b[K\r\u001b[1B\u001b[K\r\u001b[1B  \u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m shell commands \u001b[39m\u001b[K\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[39m I've learned the syntax. Let me write the program and build/run it.\u001b[K\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;78;186;101m⏺\u001b[39m \u001b[1mWrite\u001b[22m(hello.pr)\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  \u001b[39mWrote \u001b[1m3\u001b[22m lines to \u001b[1mhello.pr\u001b[22m\u001b[K\r\u001b[1B     \u001b[38;2;248;248;242m\u001b[2m 1 \u001b[22mmain() {\u001b[39m\u001b[K\r\u001b[1B     \u001b[38;2;248;248;242m\u001b[2m 2 \u001b[22m  print_line(\"hello, world\");\u001b[39m\u001b[K\r\u001b[1B     \u001b[38;2;248;248;242m\u001b[2m 3 \u001b[22m}\u001b[39m\u001b[K\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mCompiled and ran on the\u001b[27Gfirst\u001b[33Gtry.\u001b[38GNow\u001b[42Gthe\u001b[46Gsummary.\r\u001b[2B\u001b[38;2;78;186;101m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(SUMMARY.md)\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  \u001b[39mWrote\u001b[12G\u001b[1m44\u001b[15G\u001b[22mlines\u001b[21Gto\u001b[24G\u001b[1mSUMMARY.md\r\u001b[1B\u001b[22m \u001b[3G   \u001b[38;2;248;248;242m\u001b[2m  1 \u001b[22m# Promise \"hello, world\"\r\u001b[1B\u001b[39m     \u001b[38;2;248;248;242m\u001b[2m  2 \u001b[22m\u001b[39m\u001b[K\r\u001b[6C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 3"]
[0.000, "o", " \u001b[22m## What I built\r\u001b[6C\u001b[1B\u001b[2m 4 \u001b[22m\u001b[39m\u001b[K\r\u001b[6C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 5 \u001b[22mA minimal Promise program, `hello.pr`, with a single `main()` entry point that calls\r\u001b[5C\u001b[1B\u001b[2m  6 \u001b[22mthe auto-imported `print_line` to write `hello, world` to stdout:\r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;248;248;242m\u001b[2m  7 \u001b[22m\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m  8 \u001b[22m```promise\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;248;248;242m\u001b[2m  9 \u001b[22mmain() {\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 10 \u001b[22m  print_line(\"hello, world\");\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153m… +34 lines \u001b[39m\u001b[K\r\u001b[21C\u001b[2B\u001b[38;2;153;153;153m↑\u001b[25G86\u001b[39m\u001b[36;1H\u001b[34;3H\u001b[?25h"]
[0.038, "o", "\u001b[?25l\u001b[H\r\u001b[30B\u001b[38;2;215;119;87m✻\u001b[25G\u001b[38;2;153;153;153m99\u001b[39m\u001b[36;1H\u001b[34;3H\u001b[?25h"]
