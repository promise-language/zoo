[0.000, "o", "\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mWhat I learned about Promise\u001b[32G\u001b[22m(it's\u001b[38Gnot\u001b[42Gin\u001b[45Gmy\u001b[48Gtraining\u001b[57Gdata,\u001b[63Gso\u001b[66GI\u001b[68Gread\u001b[73G\u001b[38;2;177;185;249mpromise --help\u001b[88G\u001b[39mand\u001b[92G\u001b[38;2;177;185;249mpromise guide\u001b[106G\u001b[39mfirst):\r\u001b[2C\u001b[2B- \u001b[38;2;177;185;249mstd\u001b[39m is auto-imported, so \u001b[38;2;177;185;249mprint_line\u001b[39m needs no \u001b[38;2;177;185;249muse\u001b[39m and \u001b[38;2;177;185;249mmain()\u001b[39m needs no return type —\u001b[88Gthe\u001b[92Gwhole program\u001b[106Gis three\u001b[115Glines.\r\u001b[2C\u001b[1B-\u001b[5G\u001b[38;2;177;185;249mpromise run\u001b[17G\u001b[39mcompiles\u001b[26G+\u001b[28Gruns\u001b[33Gin\u001b[36Gone\u001b[40Gstep;\u001b[46G\u001b[38;2;177;185;249mpromise build\u001b[60G\u001b[39mwould\u001b[66Gproduce\u001b[74Ga\u001b[76Gstandalone\u001b[87Gexecutable.\r\u001b[4C\u001b[1BThe\u001b[9Gmost unfa\u001b[19Giliar piece is its error model: failability is marked on \u001b[3mfunctions\u001b[86G\u001b[23m(\u001b[38;2;177;185;249mmain!()\u001b[39m), not types, and the\u001b[K\r\u001b[2C\u001b[1Btrailing operat\u001b[19Grs are\u001b[26Geasy to confuse — \u001b[38;2;177;185;249m?^\u001b[39m propagates, \u001b[38;2;177;185;249m?!\u001b[39m panics, \u001b[38;2;177;185;249m? e {}\u001b[39m recover"]
