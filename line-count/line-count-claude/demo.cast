[0.046, "o", "\u001b[H\r\u001b[2C\u001b[1B(as\u001b[7Gthe\u001b[11Gguide\u001b[17Gsays)\u001b[23Gor\u001b[26Gactually\u001b[35Gconsumes.\u001b[45GThe\u001b[49Gdecisive\u001b[58Gtest:\u001b[64Gdoes\u001b[69Gan\u001b[72Gexplicit\u001b[81G\u001b[38;2;177;185;249m&\u001b[83G\u001b[39mborrow\u001b[90Gparam\u001b[96Gbehave\u001b[103Gdifferently?\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39m\u001b[1mDecisive finding:\u001b[22m plain\u001b[27G\u001b[38;2;177;185;249mstring p\u001b[36G\u001b[39m\u001b[3mconsumes\u001b[45G\u001b[23mits\u001b[49Gargument\u001b[58G—\u001b[60Gonly\u001b[65G\u001b[38;2;177;185;249mstring &p\u001b[75G\u001b[39mis\u001b[78Ga\u001b[80Gshared\u001b[87Gborrow\u001b[94G(G2/G3\u001b[101Gcompile,\u001b[110GG1\r\u001b[2C\u001b[1Bdoesn't).\u001b[13GThis\u001b[18Gdirectly\u001b[27G\u001b[1mcontradicts the guide\u001b[22m,\u001b[50Gwhich\u001b[56Gsays\u001b[61G\"plain\u001b[68G\u001b[38;2;177;185;249mT\u001b[70G\u001b[39mparam\u001b[76Gis\u001b[79Ga\u001b[81Gborrow.\"\u001b[90GThat's\u001b[97Ga\u001b[99Gfourth\u001b[106Greal\u001b[111Gissue\u001b[117G(a\r\u001b[1B \u001b[3Gcompiler/doc mismatch),\u001b[27Gand it means my comment in \u001b[38;2;177;185;249mtally\u001b[60G\u001b[39mis inaccurate.\u001b[75GLet me fix that comment.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;78;186;101m⏺\u001b[3G\u001b[39m\u001b[1mUpdate\u001b[22m(main.pr)\u001b[K\r\u001b[1B\u001b[38;2;153;"]
[0.000, "o", "153;153m  ⎿  \u001b[39mAdded\u001b[12G\u001b[1m2\u001b[14G\u001b[22mlines,\u001b[21Gremoved\u001b[29G\u001b[1m2\u001b[31G\u001b[22mlines\r\u001b[1B \u001b[3G   \u001b[38;2;248;248;242m\u001b[2m 37 \u001b[22m \u001b[39m\u001b[K\r\u001b[1B     \u001b[38;2;248;248;242m\u001b[2m 38 \u001b[22m // Count one file, turning any failure into a skipped result instead of an error.\r\u001b[7C\u001b[1B\u001b[2m9\u001b[11G\u001b[22m// This never fails, so a single unreadable file cannot take down the whole batch.\r\u001b[5C\u001b[1B\u001b[38;2;220;90;90m\u001b[48;2;61;1;0m 40 -\u001b[38;2;248;248;242m// `path` is \u001b[48;2;92;2;0mconsumed\u001b[48;2;61;1;0m (`~string`) so each goroutine \u001b[48;2;92;2;0mowns\u001b[48;2;61;1;0m its copy; it is \u001b[48;2;92;2;0monly\u001b[48;2;61;1;0m \u001b[48;2;92;2;0mever\u001b[48;2;61;1;0m                     \r\u001b[5C\u001b[1B\u001b[38;2;220;90;90m 41 -\u001b[38;2;248;248;242m// borrowed by count_lines, never stored.                                                              \r\u001b[5C\u001b[1B\u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 40 +\u001b[38;2;248;248;242m// `path` is \u001b[48;2;4;71;0mowned\u001b[48;2;2;40;0m (`~string`) so each goroutine \u001b[48;2;4;71;0mhas\u001b[48;2;2;40;0m its \u001b[48;2;4;71;0mown \u001b[48;2;2;40;0mcopy; it i"]
[0.001, "o", "s \u001b[48;2;4;71;0mhanded\u001b[48;2;2;40;0m \u001b[48;2;4;71;0mto\u001b[48;2;2;40;0m                     \r\u001b[5C\u001b[1B\u001b[38;2;80;200;80m 41 +\u001b[38;2;248;248;242m// count_lines (which consumes it) and never needed again here.                                        \r\u001b[5C\u001b[1B\u001b[49m\u001b[2m 42 \u001b[22m tally(int index, ~string path) FileCount {\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 43 \u001b[22m     int lines = count_lines(path) ? e {\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m4\u001b[11G\u001b[22m        return FileCou\u001b[34Gt(index: \u001b[44Gndex, lines: 0, ok: false, error: e.message);\r\u001b[5C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mLet me reconsider the display loop — \u001b[38;2;177;185;249mstring path = paths[i]\u001b[39m and rebuild to confirm. Let\u001b[91Gme\u001b[94Gsimplify\u001b[103Git\u001b[106Gto\u001b[109Ginterpolate\r\u001b[2C\u001b[1Bdirectly,\u001b[13Gwhich\u001b[19Greads\u001b[25Gcleaner\u001b[33Gand\u001b[37Gsidesteps\u001b[47Gthe\u001b[51Gmove\u001b[56Gsemantics\u001b[66GI\u001b[68Gjust\u001b[73Guncovered.\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m \u001b[3G\u001b[39mReading \u001b[1m1\u001b[13G\u001b[22mfile…\u001b[19G\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  main.pr\r\u001b[1B\u001b[39m\u001b[K\r\u001b[1"]
