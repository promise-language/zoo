[0.000, "o", "\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39m\u001b[1mM1 is the minimal crash\u001b[22m: \u001b[38;2;177;185;249mt := go count_for(owned); <-t\u001b[39m with\u001b[63Ga\u001b[65Gheap\u001b[70G\u001b[38;2;177;185;249mstring\u001b[77G\u001b[39marg\u001b[81Gdouble-frees.\u001b[95GLet\u001b[99Gme\u001b[102Grun\u001b[106Ga\u001b[108Gtight\u001b[114Gcontrol\r\u001b[2C\u001b[1Bmatrix\u001b[10Gto\u001b[13Gcharacterize\u001b[26Git\u001b[29Gprecisely\u001b[39Gfor\u001b[43Gthe\u001b[47Gbug\u001b[51Greport.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mNow I have a precise\u001b[24Gbug characterization. The trigger is the \u001b[38;2;177;185;249m\u001b[1mTask[T]\u001b[39m handle form\u001b[22m (\u001b[38;2;177;185;249mt := go f(...); <-t\u001b[39m) consu\u001b[113Ging a\u001b[K\r\u001b[2C\u001b[1B\u001b[1mheap\u001b[22m string argument — it doubl\u001b[35G-frees. The \u001b[38;2;177;185;249mgo {} block + channel\u001b[39m form is clean (C6). I'll\u001b[94Guse channe\u001b[105Gs. Let me\u001b[115Gverify\r\u001b[2C\u001b[1Btwo\u001b[7Gmore\u001b[12Gbuilding\u001b[21Gblocks\u001b[28Gfor\u001b[32Gthe\u001b[36Greal\u001b[41Gprogram:\u001b[50G\u001b[38;2;177;185;249mwhile\u001b[39m-"]
