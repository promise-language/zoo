[0.024, "o", "\u001b[H\r\u001b[2C\u001b[2BLet m\u001b[9G probe the concurrency patterns — task handles in\u001b[59Ga vector vs. channel capture in goroutines.\u001b[K\r\u001b[2C\u001b[4BThe indexed \u001b[38;2;177;185;249mfor\u001b[39m consumed \u001b[38;2;177;185;249mdata\u001b[39m. L\u001b[36Gt me cache\u001b[47Glength\u001b[54Gfirst and confirm the channel/goroutine capture\u001b[102Gworks.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[2C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mChannel\u001b[11Gfan-out\u001b[19Gworks.\u001b[26GNow\u001b[30Gtest\u001b[35Gcapturing\u001b[45Ga\u001b[47G\u001b[38;2;177;185;249mstring\u001b[54G\u001b[39mpath\u001b[59G(move\u001b[65Gtype)\u001b[71Gper-goroutine,\u001b[86Gand\u001b[90Gordered\u001b[98Gcollection\u001b[109Gby\u001b[112Gindex.\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[38;2;177;185;249mResult?[].filled(...)\u001b[25G\u001b[39mtripped\u001b[33Gthe\u001b[37Gparser\u001b[44Gon\u001b[47G\u001b[38;2;177;185;249m?\u001b[39m.\u001b[50GLet\u001b[54Gme\u001b[57Gcheck\u001b[63Gthe\u001b[67Gstd\u001b[71Gvector\u001b[78GAPI\u001b[82Gfor\u001b[86G\u001b[38;2;177;185;249mfilled\u001b[39m/\u001b[38;2;177;185;249msort\u001b[98G\u001b[39mand\u001b[102Gthe\u001b[106Gright\r\u001b[2C\u001b[1Boptio"]
