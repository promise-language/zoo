[0.017, "o", "\u001b[H\r\u001b[1B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mT10 gives garbage\u001b[21G(dangling\u001b[31Gborrow),\u001b[40GT12\u001b[44Gcrashes\u001b[52Geven\u001b[57Gawaiting\u001b[66Gimmediately.\u001b[79GVector\u001b[86Gsubscript\u001b[96Greturns\u001b[104G\u001b[38;2;177;185;249mT\u001b[106G\u001b[39mdirectly\u001b[115G(my\u001b[119G\u001b[38;2;177;185;249m!\r\u001b[2C\u001b[1B\u001b[39mwas\u001b[7Gwrong).\u001b[15GLet\u001b[19Gme\u001b[22Gtest\u001b[27Gwhether\u001b[35Gthe\u001b[39Gtrigger\u001b[47Gis\u001b[50G\u001b[38;2;177;185;249mfor p in paths\u001b[65G\u001b[39mspecifically\u001b[78Gvs\u001b[81Gany\u001b[85Gvector-element\u001b[100Gclone.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mT13 also crashes (it's\u001b[26Gthe \u001b[38;2;177;185;249mTask[T]\u001b[39m handle form with heap-string\u001b[67Gargs,\u001b[73Gnot\u001b[77G\u001b[38;2;177;185;249mfor\u001b[39m-specific).\u001b[92GT14's\u001b[98Gerror\u001b[104Gis\u001b[107Gjust\u001b[112Gthe\r\u001b[2C\u001b[1Bfor-loop-consumes-vector\u001b[28Gissue\u001b[34Gagain.\u001b[41GLet\u001b[45Gme\u001b[48Gfind\u001b[53Gthe\u001b[57Gminimal\u001b[65Gtask-handle\u001b[77Gcrash\u001b[83Gand\u001b[87Gconfirm\u001b[95Gthe\u001b[99Gchannel\u001b[107Gdes"]
[0.000, "o", "ign\u001b[114Gis\r\u001b[2C\u001b[1Bfully clean.\u001b[K\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[24G\u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39m\u001b[1mM1 is the minimal crash\u001b[22m:\u001b[28G\u001b[38;2;177;185;249mt := go count_for(owned); <-t\u001b[39m \u001b[59Gith\u001b[63Ga heap\u001b[70G\u001b[38;2;177;185;249mstring\u001b[39m arg double-frees. Let me\u001b[102Grun a \u001b[110Gght\u001b[114Gcontrol\r\u001b[2C\u001b[1Bmatrix\u001b[10Gto\u001b[13Gcharacterize\u001b[26Git\u001b[29Gprecisely\u001b[39Gfor\u001b[43Gthe\u001b[47Gbug\u001b[51Greport.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mNow I hav\u001b[14Ga precise\u001b[24Gbug characterization. The\u001b[50Gtrigger\u001b[58Gis\u001b[61Gthe\u001b[65G\u001b[38;2;177;185;249m\u001b[1mTask[T]\u001b[39m handle form\u001b[85G\u001b[22m(\u001b[38;2;177;185;249mt := go f(...); <-t\u001b[39m)\u001b[107Gconsuming\u001b[117Ga\r\u001b[2C\u001b[1B\u001b[1mheap\u001b[8G\u001b[22mstring\u001b[15Gargument\u001b[24G—\u001b[26Git\u001b[29Gdouble-frees.\u001b[43GThe\u001b[47G\u001b[38;2;177;185;249mgo {} block + channel\u001b[69G\u001b[39mform\u001b[74Gis\u001b[77Gclean\u001b[83G(C6).\u001b[89GI'll\u001b[94Guse\u001b[98Gchannels.\u001b[108GLet\u001b[112Gme\u001b[115Gverify\r\u001b[1B \u001b[3G"]
