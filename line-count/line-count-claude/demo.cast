[0.000, "o", " \u001b[38;5;252mproduced a stream of \"use of moved variable\" errors on code the guide says is\u001b[0m\u001b[38;5;252m valid,\u001b[0m\r\n\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mand pushed me to redesign the result struct so it no longer stores the path (the\u001b[0m\u001b[38;5;252m path\u001b[0m\r\n\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mlist already lives in \u001b[0m\u001b[38;5;203;48;5;236m main \u001b[0m\u001b[38;5;252m). Explicit \u001b[0m\u001b[38;5;203;48;5;236m string &p \u001b[0m\u001b[38;5;252m is the real borrow. (Bug #4\u001b[0m\u001b[38;5;252m below.)\u001b[0m\r\n\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252m• \u001b[0m\u001b[38;5;252;1mThree different inputs crashed the \u001b[0m\u001b[38;5;252;1;3mcompiler\u001b[0m\u001b[38;5;252;1m itself\u001b[0m\u001b[38;5;252m (Go panics / LLVM-IR\u001b[0m\u001b[38;5;252m errors),\u001b[0m\r\n\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mrather than producing diagnostics. Each took some bisection to pin to a\u001b[0m\u001b[38;5;252m minimal\u001b[0m\r\n\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mtrigger. (Bugs #2 and #3, plus #1's runtime\u001b[0m\u001b[38;5;252m abort.)\u001b[0m\r\n\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;"]
