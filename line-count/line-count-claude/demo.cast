[0.000, "o", "x: index, path: path, lines: 0, ok: false, error: e.message);             \r\u001b[1B\u001b[49m\u001b[39m \u001b[3G   \u001b[38;2;248;248;242m\u001b[2m 44 \u001b[22m     };\u001b[39m\u001b[K\r\u001b[1B     \u001b[38;2;248;248;242m\u001b[2m 45 \u001b[22m     return FileCount(index: index, path: path, lines: lines, ok: true, error: \"\");\r\u001b[7C\u001b[1B\u001b[2m6\u001b[11G\u001b[22m}\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[38;2;177;185;249mcount_lines(path)\u001b[39m is reported as moving \u001b[38;2;177;185;249mpath\u001b[39m, even though \u001b[38;2;177;185;249mcount_lines\u001b[39m takes a borrow. Let me probe why passing an\r\u001b[2C\u001b[1Bowned \u001b[38;2;177;185;249m~string\u001b[39m to\u001b[20Ga\u001b[22Gborrow\u001b[29Gparam\u001b[35Gcounts\u001b[42Gas\u001b[45Ga\u001b[47Gmove.\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m⏺\u001b[3G\u001b[39mRunning \u001b[1m1\u001b[13G\u001b[22mshell\u001b[19Gcommand…\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  $ cd /tmp/cprobe\r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;153;153;153mprobe ()\u001b[15G{ echo \"=== $1 ===\"; cat > main.pr; promise build 2>&1 | head -6; echo \"(exit ${PIPESTATUS[0]})\"; echo; }\r\u001b[5C\u001b[1Bprobe "]
