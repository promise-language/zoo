[0.033, "o", "\u001b[H\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mBug\u001b[7G#1\u001b[10Gconfirmed.\u001b[21GNow\u001b[25Gbugs\u001b[30G#2\u001b[33Gand\u001b[37G#3\u001b[40G—\u001b[42Glet\u001b[46Gme\u001b[49Gminimize\u001b[58G#2\u001b[61Gwithout\u001b[69Gthe\u001b[73G\u001b[38;2;177;185;249mio\u001b[76G\u001b[39mdependency\u001b[87G(a\u001b[90Guser-defined\u001b[103Gfailable\u001b[112Gfactory)\r\u001b[2C\u001b[1Band confirm #3's trigger\u001b[28Gand\u001b[32Gcontrols.\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mBug #2 minimized cleanly\u001b[28G(no\u001b[32G\u001b[38;2;177;185;249mio\u001b[35G\u001b[39mneeded).\u001b[44GNow\u001b[48Gbug\u001b[52G#3:\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mAll three codeg\u001b[19Gn bugs have verified repros and controls. There's\u001b[69Galso\u001b[74Ga\u001b[76G\u001b[1mfourth\u001b[83G\u001b[22missue\u001b[89GI\u001b[91Ghit\u001b[95G—\u001b[97Gthe\u001b[101Gmove-checker\r\u001b[2C\u001b[1Brejected\u001b[12Gmoving\u001b[19G\u001b[38;2;177;185;249mpath\u001b[24G\u001b[39mafter\u001b[30Ga\u001b[32G\u001b[38;2;177;185;249mborrow-call(path) ? e {…}\u001b[58G\u001b[39meven\u001b[63Gwhen\u001b[68Git's\u001b[73Gmoved\u001b[79Gonly\u001b[84Gonce\u001b[89G(P5).\u001b[95GLet\u001b[99Gme\u001b[102Gcharacterize\u001b["]
[0.000, "o", "115Gthat\r\u001b[2C\u001b[1Bprecisely, since a borrow-call\u001b[34Gshouldn't\u001b[44Gmove\u001b[49Gits\u001b[53Gargument.\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mSurprising\u001b[14G—\u001b[16GF1\u001b[19Gshows\u001b[25Geven\u001b[30Ga\u001b[32G\u001b[1mnon-failable\u001b[45G\u001b[22mborrow\u001b[52Gcall\u001b[57Gpoisons\u001b[65Gthe\u001b[69Glater\u001b[75Gmove;\u001b[81GF4\u001b[84Gshows\u001b[90Ga\u001b[92Glater\u001b[98G\u001b[3mborrow\u001b[105G\u001b[23mis\u001b[108Gstill\u001b[114Gfine.\r\u001b[2C\u001b[1BSo\u001b[6Git's\u001b[11G\"borrow-call-then-move\",\u001b[36Gnot\u001b[40Gfailable-specific.\u001b[59GLet\u001b[63Gme\u001b[66Gpin\u001b[70Gwhether\u001b[78Git's\u001b[83Gtied\u001b[88Gto\u001b[91G\u001b[38;2;177;185;249m~string\u001b[99G\u001b[39mparams\u001b[106Gor\u001b[109Gany\u001b[113Gowned\r\u001b[2C\u001b[1Bvalue.\u001b[K\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mF8\u001b[6Gis\u001b[9Gstriking\u001b[18G—\u001b[20Geven\u001b[25G\u001b[38;2;177;185;249m.clone()\u001b[34G\u001b[39mafter\u001b[40G\u001b[38;2;177;185;249mlook(path)\u001b[51G\u001b[39mis\u001b[54Grejected.\u001b[64GThis\u001b[69Ghinges\u001b[76Gon\u001b[79Gwhether\u001b[87Gplain\u001b[93G\u001b[38;2;177;185;249mstring p\u001b[102G\u001b[39mis\u001b[105Gtruly\u001b[11"]
[0.000, "o", "1Ga\u001b[113Gborrow\r\u001b[1B \u001b[3G(as the\u001b[11Gguid\u001b[16G says) or actually\u001b[35Gconsumes.\u001b[45GThe\u001b[49Gdecisive\u001b[58Gtest:\u001b[64Gdoes\u001b[69Gan\u001b[72Gexplicit\u001b[81G\u001b[38;2;177;185;249m&\u001b[83G\u001b[39mborrow\u001b[90Gparam\u001b[96Gbehave\u001b[103Gdifferently?\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell c\u001b[17Gmmand\u001b[23G\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39m\u001b[1mDecisive finding:\u001b[22m plain\u001b[27G\u001b[38;2;177;185;249mstring p\u001b[36G\u001b[39m\u001b[3mconsumes\u001b[45G\u001b[23mits\u001b[49Gargument\u001b[58G—\u001b[60Gonly\u001b[65G\u001b[38;2;177;185;249mstring &p\u001b[75G\u001b[39mis\u001b[78Ga\u001b[80Gshared\u001b[87Gborrow\u001b[94G(G2/G3\u001b[101Gcompile,\u001b[110GG1\r\u001b[2C\u001b[1Bdoesn't). This directly \u001b[1mcontradicts the guide\u001b[22m,\u001b[50Gwhich\u001b[56Gsays\u001b[61G\"plain\u001b[68G\u001b[38;2;177;185;249mT\u001b[70G\u001b[39mparam\u001b[76Gis\u001b[79Ga\u001b[81Gborrow.\"\u001b[90GThat's\u001b[97Ga\u001b[99Gfourth\u001b[106Greal\u001b[111Gissue\u001b[117G(a\r\u001b[2C\u001b[1Bcompiler/doc mismatch), and it means my comment in \u001b[38;2;177;185;249mtally\u001b[39m is\u001b[63Ginaccurate.\u001b[75GLet\u001b[79Gme\u001b[82Gfix\u001b[86Gthat\u001b[91Gcomment.\u001b[36;1H\u001b[34;3H"]
