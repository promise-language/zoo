[0.000, "o", "\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mpresent (via \u001b[0m\u001b[38;5;203;48;5;236m io.File.read_line \u001b[0m\u001b[38;5;252m), so a file ending without a newline still counts\u001b[0m\u001b[38;5;252m its\u001b[0m\r\n\u001b[H\u001bM\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mLine semantics: it counts each newline-terminated line plus a final unterminated line\u001b[0m\u001b[38;5;252m if\u001b[0m\r\n\u001b[H\u001bM  \r\n\u001b[H\u001bM\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mwith \u001b[0m\u001b[38;5;203;48;5;236m promise build \u001b[0m\u001b[38;5;252m.\u001b[0m\r\n\u001b[H\u001bM\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mreadable files. Scaffolded with \u001b[0m\u001b[38;5;203;48;5;236m promise init \u001b[0m\u001b[38;5;252m, built to a single self-contained\u001b[0m\u001b[38;5;252m binary\u001b[0m\r\n\u001b[H\u001bM\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mas skipped — one bad path can't crash the run, and the grand total counts only\u001b[0m\u001b[38;5;252m the\u001b[0m\r\n\u001b[H\u001bM\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mfiles (missing, no permission, etc.) are caught with a \u001b[0m\u001b[38;5;203;48;5;236m ? e { ... } \u001b[0m\u001b[38;5;252m handler and\u001b[0m\u001b[38;5;252m reported\u001b[0m\r\n\u001b[36;"]
