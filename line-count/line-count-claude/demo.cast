[0.000, "o", "\u001b[H\u001bM\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252min the original argument order even though goroutines finish in any order.\u001b[0m\u001b[38;5;252m Unreadable\u001b[0m\r\n\u001b[H\u001bM\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252minto a \u001b[0m\u001b[38;5;203;48;5;236m map[int, FileCount] \u001b[0m\u001b[38;5;252m keyed by the file's argument index so the output is\u001b[0m\u001b[38;5;252m printed\u001b[0m\r\n\u001b[H\u001bM\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mtotal. Each goroutine sends its result down a \u001b[0m\u001b[38;5;203;48;5;236m channel[FileCount] \u001b[0m\u001b[38;5;252m; \u001b[0m\u001b[38;5;203;48;5;236m main \u001b[0m\u001b[38;5;252m gathers\u001b[0m\u001b[38;5;252m them\u001b[0m\r\n\u001b[H\u001bM\u001b[0m\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mlines in each, \u001b[0m\u001b[38;5;252;1mone goroutine per file\u001b[0m\u001b[38;5;252m, then prints a per-file count and a\u001b[0m\u001b[38;5;252m grand\u001b[0m\r\n\u001b[H\u001bM\u001b[38;5;252m\u001b[0m\u001b[38;5;252m\u001b[0m  \u001b[38;5;252mA small command-line tool (\u001b[0m\u001b[38;5;203;48;5;236m main.pr \u001b[0m\u001b[38;5;252m) that takes file paths as arguments and counts\u001b[0m\u001b[38;5;252m the\u001b[0m\r\n\u001b[H\u001bM\u001b[0m  \r\n\u001b[H\u001bM\u001b[0m\u001b[38;5;39;1m\u001b[0m\u001b[38;5;39;1"]
