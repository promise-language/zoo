// mini-git — a self-contained, content-addressed version-control tool.
//
// All state lives on disk under .minigit/:
//   objects/<hash>  raw file bytes, content-addressed with FNV-1a (16 hex digits)
//   commits/<id>    a commit's canonical text; its id is the FNV-1a of that text
//   HEAD            the current commit id (empty/absent when there are no commits)
//   index           the staging area: sorted "<hash> <filename>" lines
//
// Output is deterministic: filenames and a commit's files are always sorted, and
// every expected failure prints a clear "mini-git: …" message and exits with 1.

use io;
use os;
use time;

// ---------------------------------------------------------------------------
// Repository paths
// ---------------------------------------------------------------------------

get REPO    string => ".minigit";
get OBJECTS string => ".minigit/objects";
get COMMITS string => ".minigit/commits";
get HEAD    string => ".minigit/HEAD";
get INDEX   string => ".minigit/index";

// ---------------------------------------------------------------------------
// A commit, as held in memory. `time` stays a string — we only ever print it,
// so there is no need to parse it back into a number.
// ---------------------------------------------------------------------------

type Commit {
  string id                    `final;
  string parent                `final;   // "" when this is the root commit
  string time                  `final;   // Unix seconds, as text
  string message               `final;
  map[string, string] files    `final;   // filename -> blob hash
}

// ---------------------------------------------------------------------------
// Byte-level file I/O (blobs are binary-safe — never routed through `string`)
// ---------------------------------------------------------------------------

read_bytes!(string path) u8[] {
  use f := io.File.open(path, readonly: true);
  u8[] out = [];
  u8[] chunk = u8[].filled(0u8, count: 65536);
  while true {
    int got = f.read(chunk);
    if got == 0 { break; }
    for i in 0..got { out.push(chunk[i]); }
  }
  return out;
}

write_bytes!(string path, u8[]~ data) {
  use f := io.File.create(path);
  f.write(data);
}

// ---------------------------------------------------------------------------
// FNV-1a (64-bit) content hashing → 16 lowercase hex digits
// ---------------------------------------------------------------------------

fnv1a_hex(u8[] data) string {
  u64 h = 14695981039346656037u64;       // FNV offset basis
  for b in data {
    h = h ^ (b as u64);
    h = h * 1099511628211u64;             // FNV prime (wraps mod 2^64)
  }
  return to_hex16(h);
}

to_hex16(u64 v) string {
  string digits = "0123456789abcdef";
  string s = "";
  for i in 0..16 {
    u64 shift = (((15 - i) * 4) as u64);  // most-significant nibble first
    int idx = ((v >> shift) & 15u64) as int;
    s = s + "{digits[idx]}";
  }
  return s;
}

// ---------------------------------------------------------------------------
// Staging area (the index)
// ---------------------------------------------------------------------------

load_index!() map[string, string] {
  map[string, string] idx = {:};
  // Note: written as one branch (not an early `return idx`) — moving `idx` out
  // of a returning branch trips a move-analysis bug (see BUG-branch-return-moves-variable).
  if io.File.exists(INDEX) {
    string content = io.File.read_content(INDEX);
    for line in content.split("\n") {
      if line.is_empty { continue; }
      string h    = line[:16];            // a hash is always 16 hex chars …
      string name = line[17:];            // … then a space, then the filename
      idx[name] = h;
    }
  }
  return idx;
}

save_index!(map[string, string] idx) {
  string text = "";
  for name in sort[string](idx.keys()) {
    text = text + "{idx[name]!} {name}\n";
  }
  io.File.write_content(INDEX, text);
}

clear_index!() {
  io.File.write_content(INDEX, "");
}

// ---------------------------------------------------------------------------
// HEAD pointer
// ---------------------------------------------------------------------------

read_head!() string {
  if !io.File.exists(HEAD) { return ""; }
  return io.File.read_content(HEAD).trim();
}

write_head!(string id) {
  io.File.write_content(HEAD, id);
}

// ---------------------------------------------------------------------------
// Commit serialization / parsing. The serialized text is hashed verbatim to
// produce the commit id, so the format is canonical: sorted file lines, then a
// lone "message" sentinel, then the (possibly multi-line) message.
// ---------------------------------------------------------------------------

serialize_commit(string parent, string time_str, string message, map[string, string] files) string {
  string text = "parent {parent}\ntime {time_str}\n";
  for name in sort[string](files.keys()) {
    text = text + "file {files[name]!} {name}\n";
  }
  return text + "message\n" + message;
}

parse_commit(string id, string content) Commit {
  string parent = "";
  string time_str = "";
  string message = "";
  map[string, string] files = {:};
  bool in_message = false;
  bool first_msg_line = true;

  for line in content.split("\n") {
    if in_message {
      // Everything after the "message" sentinel is the message, verbatim.
      if !first_msg_line { message = message + "\n"; }
      message = message + line;
      first_msg_line = false;
    } else if line == "message" {
      in_message = true;
    } else if line.starts_with("parent ") {
      parent = line[7:];
    } else if line.starts_with("time ") {
      time_str = line[5:];
    } else if line.starts_with("file ") {
      string rest = line[5:];
      files[rest[17:]] = rest[:16];       // name -> hash
    }
  }

  return Commit(id: id.clone(), parent: move parent, time: move time_str,
                message: move message, files: move files);
}

commit_exists(string id) bool => io.File.exists("{COMMITS}/{id}");

load_commit!(string id) Commit {
  return parse_commit(id, io.File.read_content("{COMMITS}/{id}"));
}

// ---------------------------------------------------------------------------
// Guards & argument helpers
// ---------------------------------------------------------------------------

require_repo!() {
  if !io.Dir.exists(REPO) {
    raise error(message: "not a mini-git repository (run 'mini-git init' first)");
  }
}

require_commit!(string id) {
  if !commit_exists(id) {
    raise error(message: "unknown commit '{id}'");
  }
}

arg_at!(string[] a, int i, string usage) string {
  if i >= a.len {
    raise error(message: "usage: mini-git {usage}");
  }
  return a[i].clone();
}

// ---------------------------------------------------------------------------
// Commands
// ---------------------------------------------------------------------------

cmd_init!() {
  if io.Dir.exists(REPO) {
    print_line("mini-git: repository already exists at {REPO}/");
    return;                               // already-initialized is not an error
  }
  io.Dir.make_all(OBJECTS);
  io.Dir.make_all(COMMITS);
  print_line("Initialized empty mini-git repository in {REPO}/");
}

cmd_add!(string file) {
  require_repo();
  if !io.File.exists(file) {
    raise error(message: "cannot add '{file}': no such file");
  }
  u8[] data = read_bytes(file);
  string h = fnv1a_hex(data);
  write_bytes("{OBJECTS}/{h}", data);

  map[string, string] idx = load_index();
  idx[file] = h.clone();                  // clone: a map-inserted heap string is
  save_index(idx);                        // consumed but not flagged, so reusing
  print_line("added {file}  ({h})");      // `h` after save_index would read empty
                                          // (see BUG-map-assign-moves-heap-string)
}

cmd_rm!(string file) {
  require_repo();
  map[string, string] idx = load_index();
  if !idx.contains(file) {
    raise error(message: "'{file}' is not staged");
  }
  idx.remove(file);
  save_index(idx);
  print_line("removed {file}");
}

cmd_status!() {
  require_repo();
  map[string, string] idx = load_index();
  if idx.is_empty {
    print_line("nothing staged");
    return;
  }
  print_line("Staged files:");
  for name in sort[string](idx.keys()) {
    print_line("  {name}");
  }
}

cmd_commit!(string[] a) {
  require_repo();

  string? message = none;
  for i := 1; i < a.len; i += 1 {
    if a[i] == "-m" {
      if i + 1 >= a.len {
        raise error(message: "commit -m requires a message");
      }
      message = a[i + 1].clone();
      break;
    }
  }
  if message is absent {
    raise error(message: "usage: mini-git commit -m \"<message>\"");
  }

  map[string, string] idx = load_index();
  if idx.is_empty {
    raise error(message: "nothing staged to commit");
  }

  string time_str = "{time.DateTime.now().unix_secs}";
  string text = serialize_commit(read_head(), time_str, message, idx);
  string id = fnv1a_hex(text.bytes());

  io.File.write_content("{COMMITS}/{id}", text);
  write_head(id);
  clear_index();
  print_line("committed {id}");
}

cmd_log!() {
  require_repo();
  string cur = read_head();
  if cur.is_empty {
    print_line("no commits yet");
    return;
  }
  while !cur.is_empty {
    Commit c = load_commit(cur);
    print_line("commit {c.id}");
    print_line("date   {c.time}");
    print_line("    {c.message}");
    print_line("");
    cur = c.parent;
  }
}

cmd_show!(string id) {
  require_repo();
  require_commit(id);
  Commit c = load_commit(id);
  print_line("commit  {c.id}");
  print_line("date    {c.time}");
  print_line("message {c.message}");
  print_line("files:");
  for name in sort[string](c.files.keys()) {
    print_line("  {c.files[name]!} {name}");
  }
}

cmd_diff!(string a_id, string b_id) {
  require_repo();
  require_commit(a_id);
  require_commit(b_id);
  Commit a = load_commit(a_id);
  Commit b = load_commit(b_id);

  // Union of both file sets, sorted, so the report is deterministic.
  map[string, bool] all = {:};
  for name in a.files.keys() { all[name] = true; }
  for name in b.files.keys() { all[name] = true; }

  for name in sort[string](all.keys()) {
    bool in_a = a.files.contains(name);
    bool in_b = b.files.contains(name);
    if !in_a {
      print_line("added    {name}");
    } else if !in_b {
      print_line("removed  {name}");
    } else if a.files[name]! != b.files[name]! {
      print_line("modified {name}");
    }
  }
}

cmd_checkout!(string id) {
  require_repo();
  require_commit(id);
  Commit c = load_commit(id);
  for name in sort[string](c.files.keys()) {
    u8[] data = read_bytes("{OBJECTS}/{c.files[name]!}");
    write_bytes(name, data);
  }
  write_head(id);
  clear_index();
  print_line("checked out {id}");
}

cmd_reset!(string id) {
  require_repo();
  require_commit(id);
  write_head(id);                         // move HEAD only — working tree untouched
  clear_index();
  print_line("reset to {id}");
}

// ---------------------------------------------------------------------------
// Dispatch
// ---------------------------------------------------------------------------

run!() {
  string[] a = os.args;
  if a.is_empty {
    raise error(message: "usage: mini-git <init|add|rm|status|commit|log|show|diff|checkout|reset>");
  }
  match a[0] {
    "init"     => { cmd_init(); },
    "add"      => { cmd_add(arg_at(a, 1, "add <file>")); },
    "rm"       => { cmd_rm(arg_at(a, 1, "rm <file>")); },
    "status"   => { cmd_status(); },
    "commit"   => { cmd_commit(a); },
    "log"      => { cmd_log(); },
    "show"     => { cmd_show(arg_at(a, 1, "show <commit>")); },
    "diff"     => { cmd_diff(arg_at(a, 1, "diff <commit-a> <commit-b>"), arg_at(a, 2, "diff <commit-a> <commit-b>")); },
    "checkout" => { cmd_checkout(arg_at(a, 1, "checkout <commit>")); },
    "reset"    => { cmd_reset(arg_at(a, 1, "reset <commit>")); },
    _          => { raise error(message: "unknown command '{a[0]}'"); },
  }
}

main() {
  run() ? e {
    print_line("mini-git: {e.message}");
    os.exit_process(1);
  };
}
