[0.018, "o", "\u001b[H\r\u001b[1B \u001b[3Gc\u001b[5Geck context and learn Prom\u001b[32Gse.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRead \u001b[1m1\u001b[22m file, ran \u001b[1m1\u001b[22m shell command \r\u001b[2C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mThis\u001b[8Gis\u001b[11Ga\u001b[13Gre-record\u001b[23Gagainst\u001b[31Gthe\u001b[35Gnewer\u001b[41G2026.1\u001b[48Gtoolchain\u001b[58G(prior\u001b[65Grun\u001b[69Gwas\u001b[73Gon\u001b[76G2026.1\u001b[83Gtoo\u001b[87Gper\u001b[91Gcontext,\u001b[100Gbut\u001b[104Gthe\u001b[108Gprior\r\u001b[1B \u001b[3Gbug\u001b[7G/featu\u001b[15G gap are in gi\u001b[31Ghistory).\u001b[41GI'll build fresh\u001b[58Gas a fi\u001b[66Gst\u001b[69Grun\u001b[73Gwould. Let me\u001b[87Gl\u001b[89Garn Promise from the t\u001b[112Golchain.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m shell commands \r\u001b[2C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mNow\u001b[7Glet\u001b[11Gme\u001b[14Gcheck\u001b[20Gthe\u001b[24Gspecific\u001b[33Gstdlib\u001b[40GAPIs\u001b[45GI'll\u001b[50Gneed:\u001b[56Gfile\u001b[61Gbytes\u001b[67GI/O,\u001b[72Gcommand-line\u001b[85Gargs,\u001b[91Gtime,\u001b[97Gand\u001b[101Gexit.\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m shell commands \r\u001b[2C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mLet\u001b[7Gme\u001b[10Gsee\u001b[14Gthe\u001b[18Grest\u001b[23Gof\u001b[26G\u001b[38;2;17"]
[0.000, "o", "7;185;249mos\u001b[29G\u001b[39m(args,\u001b[36Gexit,\u001b[42Gtime)\u001b[48Gand\u001b[52Gcheck\u001b[58Gfor\u001b[62Ga\u001b[64Gtime\u001b[69Gmodule.\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m shell commands \r\u001b[2C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[38;2;177;185;249mtime\u001b[8G\u001b[39mis\u001b[11Gstill\u001b[17Ga\u001b[19Gplaceholder.\u001b[32GLet\u001b[36Gme\u001b[39Gcheck\u001b[45Gthe\u001b[49Gtime\u001b[54Gmodule\u001b[61Gand\u001b[65Gio.Dir,\u001b[73Gplus\u001b[78Ghow\u001b[82Gto\u001b[85Ghash\u001b[90Gbytes\u001b[96G(std\u001b[101Ghashing).\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B  ⎿  $ promise doc time 2>&1 | head -80; echo \"=====DIR=====\"; promise doc io 2>&1 | sed -n '150,260p'\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[39m\u001b[K\u001b[30;1H\u001b[28;3H"]
[0.022, "o", "\u001b[H\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mThis\u001b[8Gis\u001b[11Ga\u001b[13Gre-record\u001b[23G(toolchain\u001b[34Gmoved\u001b[40Gto\u001b[43G2026.1).\u001b[52GThe\u001b[56Grun\u001b[60Gdir\u001b[64Gwas\u001b[68Gwiped,\u001b[75Gleaving\u001b[83Gonly\u001b[88G\u001b[38;2;177;185;249mcontext.md\u001b[99G\u001b[39mand\u001b[103G\u001b[38;2;177;185;249mdemo.cast\u001b[39m.\u001b[114GLet\u001b[118Gme\r\u001b[21B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;177;185;249mDateTime.now()\u001b[18G\u001b[39mexists\u001b[25Gnow\u001b[29G—\u001b[31Gthe\u001b[35Gprior\u001b[41Grun's\u001b[47Gmissing-feature\u001b[63Ggap\u001b[67Gmay\u001b[71Gbe\u001b[74Gclosed.\u001b[82GLet\u001b[86Gme\u001b[89Gtest\u001b[94Gwhether\u001b[102G\u001b[38;2;177;185;249mtime.now()\u001b[113G\u001b[39mactually\r\u001b[2B\u001b[38;2;215;119;87m✶\u001b[5G\u001b[38;2;235;159;127me\u001b[8G\u001b[38;2;215;119;87mp\u001b[39m\u001b[30;1H\u001b[28;3H"]
