[0.117, "o", "\u001b[H\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mThe blob hashes\u001b[19Gare\u001b[23Gcorrect\u001b[31Gon\u001b[34Gdisk\u001b[39G(\u001b[38;2;177;185;249m2925835410388969\u001b[39m,\u001b[58G\u001b[38;2;177;185;249m15d0dddb989be669\u001b[39m)\u001b[76Gand\u001b[80Grecorded\u001b[89Gin\u001b[92Gthe\u001b[96Gcommit\u001b[103G—\u001b[105Gbut\u001b[109Gthe\u001b[113G\u001b[38;2;177;185;249m{h}\u001b[117G\u001b[39min\r\u001b[2C\u001b[1B\u001b[38;2;177;185;249madd\u001b[39m's\u001b[9Gsuccess\u001b[17Gmessage\u001b[25Gprinted\u001b[33Gempty.\u001b[40G\u001b[38;2;177;185;249mh\u001b[42G\u001b[39mis\u001b[45Gused\u001b[50Gfine\u001b[55Gin\u001b[58Gthe\u001b[62Gpath\u001b[67Ginterpolation\u001b[81G\u001b[3mbefore\u001b[88G\u001b[23m\u001b[38;2;177;185;249midx[file] = h\u001b[39m,\u001b[103Gthen\u001b[108Gprints\u001b[115Gempty\r\u001b[2C\u001b[1B\u001b[3mafter\u001b[23m. That smells like\u001b[27Ga\u001b[29Gmove\u001b[34Gbug.\u001b[39GLet\u001b[43Gme\u001b[46Gminimize\u001b[55Git.\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[24G\u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mMinimal map-assign is fine. The bug must\u001b[44Gbe\u001b[47Gmore\u001b[52Gspecific\u001b[61Gto\u001b[64G\u001b[38;2;177;185;249madd\u001b[39m's\u001b[70Gshape.\u001b[77GLet\u001b[81Gme\u001b[84Greproduce\u001b[94Gits\u001b[98Gexact\u001b[104Gpattern.\r\u001b[2B\u001b[38;2;153;153;153m⏺\u001b[3G\u001b[39mRunning \u001b[1m1\u001b["]
[0.001, "o", "22m shell command…\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  $ cd /tmp && cat > mv2.pr <<'EOF'\r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;153;153;153mget OBJECTS string => \"obj\";\r\u001b[5C\u001b[1Bhashit(u8[] data) string {\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153mreturn \"deadbeefcafe0000\";\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;2;153;153;153m}\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;2;153;153;153msink(map[string, string] m) { }\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153mgo!(string file) {\r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;153;153;153mu8[] data = [1u8, 2u8, 3u8];\r\u001b[5C\u001b[1Bstring h = hashit(data);\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153mprint_line(\"path = {OBJECTS}/{h}\");\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153mmap[string, string] idx = {:};\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153midx[file…\u001b[39m\u001b[K\r\u001b[22C\u001b[2B\u001b[38;2;153;153;153m4\u001b[39m\u001b[30;1H\u001b[28;3H"]
