[0.049, "o", "\u001b[H\u001b[6G\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mFixed. Now a thorough end-to-end test of every command, including a binary round-trip and all three diff cases.\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[5C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mAll\u001b[7Gcorrect.\u001b[16GNow\u001b[20Gcheckout\u001b[29Gvs\u001b[32Greset\u001b[38Gsemantics,\u001b[49Gbinary\u001b[56Ground-trip,\u001b[68Gdeterminism\u001b[80Gof\u001b[83Gcommit\u001b[90Gids,\u001b[95Gand\u001b[99Gthe\u001b[103Gremaining\u001b[113Gerror\r\u001b[2C\u001b[1Bcases.\u001b[K\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mcheckout restores files\u001b[27G+\u001b[29Gmoves\u001b[35GHEAD;\u001b[41Greset\u001b[47Gmoves\u001b[53GHEAD\u001b[58Gonly.\u001b[64GNow\u001b[68Gthe\u001b[72Gbinary\u001b[79Ground-trip\u001b[90Gand\u001b[94Gremaining\u001b[104Gerror/edge\u001b[115Gcases:\r\u001b[2B\u001b[38;2;153;153;153m⏺\u001b[3G\u001b[39mRunning \u001b[1m1\u001b[22m shell command…\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  $ BIN=/Users/xxxxx/prog/zoo/mini-git/mini-git-claude/mini-git-claude\r\u001b["]
[0.000, "o", "5C\u001b[1Brm -rf /tmp/mgbin && mkdir -p /tmp/mgbin && cd /tmp/mgbin\r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;153;153;153m$BIN init >/dev/null\r\u001b[5C\u001b[1Bhead -c 5000 /dev/urandom > blob.bin\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153mSHA_BEFORE=$(shasum -a 256 blob.bin | awk '{print $1}')\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153m$BIN add blob.bin >/dev/null\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153m$BIN commit -m \"binary\" >/dev…\r\u001b[23C\u001b[2B7\u001b[39m\u001b[30;1H\u001b[28;3H"]
