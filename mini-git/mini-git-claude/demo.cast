[0.019, "o", "\u001b[H\r\u001b[2C\u001b[3BAll c\u001b[9Grrect. Now checkout\u001b[29Gvs reset semantics, binary rou\u001b[60Gd-trip,\u001b[68Gdeterminism \u001b[81Gf comm\u001b[88Gt\u001b[90Gids, and the r\u001b[105Gmaining \u001b[114Grror\u001b[K\r\u001b[2C\u001b[1Bcases.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mcheckout res\u001b[16Gores\u001b[21Gfiles + moves HEAD; reset moves HEAD only. Now \u001b[69Ghe binary\u001b[79Grou\u001b[83Gd-t\u001b[87Gip a\u001b[92Gd remain\u001b[101Gng error/edge cases:\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[39m Everything passes: byte-exact binary round-trip, all error cases clean\u001b[74Gwith\u001b[79Gexit\u001b[84G1.\u001b[87GNow\u001b[91Glet\u001b[95Gme\u001b[98Gverify\u001b[105Gthe\u001b[109Gtwo\u001b[113Gbug\r\u001b[2C\u001b[1Brepros (and their controls) cleanly so I can document them accurately\u001b[73G—\u001b[75Gthe\u001b[79Gbranch-return\u001b[93Gbug\u001b[97GI\u001b[99Ghit\u001b[103Gin\u001b[106G\u001b[38;2;177;185;249mload_index\u001b[39m,\u001b[118Gand\r\u001b[2C\u001b[1Bthe new map-assign bug.\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m \u001b[3G\u001b[39mRunning \u001b[1m2\u001b[22m shell comm"]
[0.000, "o", "ands…\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  $ cd /tmp/bugverify\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153mecho \"######## BUG B: map-assign moves heap string (uncaught), corrupts on later borrow ########\"\r\u001b[5C\u001b[1Bcat > b_repro.pr <<'EOF'\r\u001b[7C\u001b[1Bke_heap(string a, string b\u001b[35G string { return a + b; } // a non-literal (heap) string\r\u001b[5C\u001b[1Btake_map(map[string, string] m) { } // merely borrows the map\r\u001b[5C\u001b[1Bmain() {…\u001b[39m\u001b[K\u001b[30;1H\u001b[28;3H"]
