[0.103, "o", "\u001b[H\u001b[3G\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mMinimal map-assign is\u001b[25Gfine\u001b[30G—\u001b[32Gso\u001b[35Gthe\u001b[39Gtrigger\u001b[47Gis\u001b[50Gmore\u001b[55Gspecific.\u001b[65GLet\u001b[69Gme\u001b[72Gbisect\u001b[79Gfrom\u001b[84Gthe\u001b[88Gfailing\u001b[96G\u001b[38;2;177;185;249mmv3\u001b[100G\u001b[39mby\u001b[103Gtoggling\u001b[112Geach\r\u001b[2C\u001b[1Bsuspect\u001b[11G(the\u001b[16G\u001b[38;2;177;185;249msink(idx)\u001b[26G\u001b[39mcall,\u001b[32Gthe\u001b[36Gparam\u001b[42Gkey,\u001b[47Gthe\u001b[51Gfailable\u001b[60Gcontext).\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mClear signal: the trigger\u001b[29Gis\u001b[32G\u001b[1mpassing the map to another function after the heap-string insert\u001b[97G\u001b[22m(A/B/D\u001b[104Gfail;\u001b[110GC,\u001b[113Gwith\u001b[118Gno\r\u001b[2C\u001b[1Bsuch\u001b[8Gcall,\u001b[14Gworks).\u001b[22GFailable-ness\u001b[36Gand\u001b[40Gkey\u001b[44Gkind\u001b[49Gare\u001b[53Girrelevant.\u001b[65GLet\u001b[69Gme\u001b[72Gconfirm\u001b[80Git's\u001b[85Gthe\u001b[89Gmap-borrow\u001b[100Gspecifically\u001b[113G(not\r\u001b[1B \u001b[3Gjust any intervening call) and check whether the map's stored value also corrupts.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b"]
[0.000, "o", "[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[24G\u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mThe trigger is pinned:\u001b[26G\u001b[38;2;177;185;249m\u001b[1mmap[key] = heapString\u001b[39m followed by passing the map to a function corrupts the source variable\r\u001b[2C\u001b[1B\u001b[22m(the\u001b[8Gmap\u001b[12Ginsert\u001b[19Gmoves\u001b[25Gthe\u001b[29Gheap\u001b[34Gstring\u001b[41Gwithout\u001b[49Gflagging\u001b[58Git;\u001b[62Gthe\u001b[66Glater\u001b[72Gread\u001b[77Gis\u001b[80Ga\u001b[82Gsilent\u001b[89Guse-after-move).\u001b[106GLet\u001b[110Gme\u001b[113Glock\u001b[118Gin\r\u001b[1B \u001b[3Ga clean d\u001b[13Gtermin\u001b[20Gstic repro, then fix the real code.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mDeterministic. Now fix\u001b[26Gthe\u001b[30Greal\u001b[35Gcode\u001b[40G(clone\u001b[47Ginto\u001b[52Gthe\u001b[56Gmap\u001b[60Gso\u001b[63Gthe\u001b[67Gsource\u001b[74Gvariable\u001b[83Gis\u001b[86Gnever\u001b[92Gmoved):\r\u001b[2B\u001b[38;2;153;153;153m⏺\u001b[3G\u001b[39m\u001b[1mUpdate\u001b[22m(main.pr)\u001b[K\u001b[30;1H\u001b[28;3H"]
[0.018, "o", "\u001b[H\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mThe\u001b[7Gtrigger\u001b[15Gis\u001b[18Gpinned:\u001b[26G\u001b[38;2;177;185;249m\u001b[1mmap[key] = heapString\u001b[39m followed by passing the map to a function corrupts the source variable\r\u001b[2C\u001b[1B\u001b[22m(the map insert moves\u001b[25Gthe\u001b[29Gheap\u001b[34Gstring\u001b[41Gwithout\u001b[49Gflagging\u001b[58Git;\u001b[62Gthe\u001b[66Glater\u001b[72Gread\u001b[77Gis\u001b[80Ga\u001b[82Gsilent\u001b[89Guse-after-move).\u001b[106GLet\u001b[110Gme\u001b[113Glock\u001b[118Gin\r\u001b[2C\u001b[1Ba\u001b[5Gclean\u001b[11Gdeterministic\u001b[25Grepro,\u001b[32Gthen\u001b[37Gfix\u001b[41Gthe\u001b[45Greal\u001b[50Gcode.\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mDeterministic. Now fix\u001b[26Gthe\u001b[30Greal\u001b[35Gcode\u001b[40G(clone\u001b[47Ginto\u001b[52Gthe\u001b[56Gmap\u001b[60Gso\u001b[63Gthe\u001b[67Gsource\u001b[74Gvariable\u001b[83Gis\u001b[86Gnever\u001b[92Gmoved):\r\u001b[2B\u001b[38;2;78;186;101m⏺\u001b[3G\u001b[39m\u001b[1mUpdate\u001b[22m(main.pr)\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  \u001b[39mAdded \u001b[1m4\u001b[14G\u001b[22mline\u001b[19G, removed \u001b[1m3\u001b[22m lines\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;2;248;248;242m\u001b[2m 223 \u001b[22m   write_bytes(\"{OBJECTS}/{h}\", data);\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242"]
[0.000, "o", "m\u001b[2m 224 \u001b[22m \r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;248;248;242m\u001b[2m 225 \u001b[22m   map[string, string] idx = load_index();\r\u001b[5C\u001b[1B\u001b[38;2;220;90;90m\u001b[48;2;61;1;0m 226 -\u001b[38;2;248;248;242m  idx[file] = h;                                                                                      \r\u001b[1B\u001b[49m\u001b[39m \u001b[3G   \u001b[38;2;220;90;90m\u001b[48;2;61;1;0m 227 -\u001b[38;2;248;248;242m  save_index(idx);                                                                                    \u001b[49m\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;2;220;90;90m\u001b[48;2;61;1;0m 228 -\u001b[38;2;248;248;242m  print_line(\"added {file}  ({h})\");                                                                  \u001b[49m\u001b[39m\u001b[K\r\u001b[2C\u001b[1B \u001b[5G \u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 226 +\u001b[38;2;248;248;242m  idx[file] = h.clone();                  // clone: a map-inserted heap string is                     \r\u001b[5C\u001b[1B\u001b[38;2;80;200;80m 227 +\u001b[38;2;248;248;242m  save_index(idx);                        // consumed but not flagged, so reusing                     \r\u001b[2C\u001b[1B\u001b[49m\u001b[39m   \u001b[38;2;80;200;80m\u001b[48;2;"]
[0.000, "o", "2;40;0m 228 +\u001b[38;2;248;248;242m  print_line(\"added {file}  ({h})\");\u001b[48;2;4;71;0m      // `h` after save_index would read empty\u001b[48;2;2;40;0m                    \r\u001b[5C\u001b[1B\u001b[38;2;80;200;80m 229 +\u001b[38;2;248;248;242m                                          // (see BUG-map-assign-moves-heap-string)                   \r\u001b[1B\u001b[49m\u001b[39m \u001b[3G   \u001b[38;2;248;248;242m\u001b[2m 230 \u001b[22m }\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 231 \u001b[22m \r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;248;248;242m\u001b[2m 232 \u001b[22m cmd_rm!(string file) {\u001b[39m\u001b[30;1H\u001b[28;3H"]
