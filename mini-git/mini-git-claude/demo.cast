[0.000, "o", "53;153m$BIN add notes.txt\r\u001b[5C\u001b[1B$BIN status\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153m$BIN commit -m \"initial notes\"\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153mprintf 'hello\\nworld\\nthird line\\n' > notes.txt\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153m$BIN add not…\u001b[39m\u001b[K\u001b[30;1H\u001b[28;3H"]
