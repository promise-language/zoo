[0.091, "o", "\u001b[H\r\u001b[2C\u001b[1Brepros\u001b[10G(and\u001b[15Gtheir\u001b[21Gcontrols)\u001b[31Gcleanly\u001b[39Gso\u001b[42GI\u001b[44Gcan\u001b[48Gdocument\u001b[57Gthem\u001b[62Gaccurately\u001b[73G—\u001b[75Gthe\u001b[79Gbranch-return\u001b[93Gbug\u001b[97GI\u001b[99Ghit\u001b[103Gin\u001b[106G\u001b[38;2;177;185;249mload_index\u001b[39m,\u001b[118Gand\r\u001b[1B \u001b[3Gth\u001b[6G new map-\u001b[18Gign\u001b[23Gug.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m shell commands \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mBoth bugs verified with\u001b[27Gcontrols.\u001b[37GNow\u001b[41Glet\u001b[45Gme\u001b[48Gwrite\u001b[54Gthe\u001b[58Gtwo\u001b[62GBUG\u001b[66Greports\u001b[74Gand\u001b[78Gthe\u001b[82GSUMMARY.\r\u001b[2B\u001b[38;2;78;186;101m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(BUG-map-assign-moves-heap-string.md)\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  \u001b[39mWrote\u001b[12G\u001b[1m92\u001b[15G\u001b[22mlines\u001b[21Gto\u001b[24G\u001b[1mBUG-map-assign-moves-heap-string.md\r\u001b[1B\u001b[22m \u001b[3G   \u001b[38;2;248;248;242m\u001b[2m  1 \u001b[22mPlease file this upstream at https://github.com/promise-language/promise/issues\r\u001b[1B\u001b[39m     \u001b[38;2;248;248;242m\u001b[2m  2 \u001b[22m\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m3\u001b[10G\u001b[22m# `map[key]\u001b[22G= heapString`\u001b[36Gconsume\u001b[44G the value with"]
[0.000, "o", "out flagging it — later u\u001b[85Ge silently reads an empty str\r\u001b[7C\u001b[1B\u001b[2m \u001b[10G\u001b[22ming\r\u001b[7C\u001b[1B\u001b[2m4\u001b[10G\u001b[22m\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m6\u001b[10G\u001b[22m- `promise version 2026.1 (channel stable, commit 4bf7e22)`\r\u001b[7C\u001b[1B\u001b[2m7\u001b[10G\u001b[22m- macOS 26.5.1 (arm64), Darwin 25.5.0\r\u001b[7C\u001b[1B\u001b[2m8\u001b[10G\u001b[22m\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m9\u001b[10G\u001b[22m## Summary\u001b[39m\u001b[K\r\u001b[6C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m10\u001b[10G\u001b[22mAssigning a **heap-allocated** `string` into a map via subscript (`m[k] = h`)\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153m… +82 lines \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m \u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(BUG-branch-return-moves-variable.md)\r\u001b[22C\u001b[2B\u001b[38;2;153;153;153m50\u001b[39m\u001b[30;1H\u001b[28;3H"]
[0.019, "o", "\u001b[H\u001b[6G\u001b[38;2;248;248;242m\u001b[2m  3 \u001b[22m# `map[key] = heapString` consumes the value without flagging it — later use silently reads an empty str\r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;248;248;242m\u001b[2m    \u001b[22ming\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;2;248;248;242m\u001b[2m  4 \u001b[11G\u001b[22m\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m  6 \u001b[22m- `promise version 2026.1 (channel stable, commit 4bf7e22)`\r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;248;248;242m\u001b[2m  7 \u001b[22m- macOS 26.5.1 (arm64), Darwin 25.5.0\r\u001b[5C\u001b[1B\u001b[2m  8 \r\u001b[1B\u001b[22m\u001b[39m \u001b[3G   \u001b[38;2;248;248;242m\u001b[2m  9 \u001b[22m## Summary\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 10 \u001b[22mAssigning a **heap-allocated** `string` into a map via subscript (`m[k] = h`)\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153m… +82 lines \u001b[39m\u001b[K\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;78;186;101m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(BUG-branch-return-moves-variable.md)\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  \u001b[39mWrote\u001b[12G\u001b[1m68\u001b[15G\u001b[22mlines\u001b[21Gto\u001b[24G\u001b[1mBUG-branch-return-moves-variable.md\r\u001b[7C\u001b[1B\u001b[22m\u001b[38;2;248;248;242m\u001b[2m1\u001b[10G\u001b[22mPlease file\u001b[22Gthis upstream\u001b[36Gat http\u001b[44"]
