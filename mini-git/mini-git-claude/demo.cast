[0.032, "o", "\u001b[H\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mEverything\u001b[14Gpasses:\u001b[22Gbyte-exact\u001b[33Gbinary\u001b[40Ground-trip,\u001b[52Gall\u001b[56Gerror\u001b[62Gcases\u001b[68Gclean\u001b[74Gwith\u001b[79Gexit\u001b[84G1.\u001b[87GNow\u001b[91Glet\u001b[95Gme\u001b[98Gverify\u001b[105Gthe\u001b[109Gtwo\u001b[113Gbug\r\u001b[2C\u001b[1Brepros (and their controls)\u001b[31Gcleanly\u001b[39Gso\u001b[42GI\u001b[44Gcan\u001b[48Gdocument\u001b[57Gthem\u001b[62Gaccurately\u001b[73G—\u001b[75Gthe\u001b[79Gbranch-return\u001b[93Gbug\u001b[97GI\u001b[99Ghit\u001b[103Gin\u001b[106G\u001b[38;2;177;185;249mload_index\u001b[39m,\u001b[118Gand\r\u001b[2C\u001b[1Bthe\u001b[7Gnew\u001b[11Gmap-assign\u001b[22Gbug.\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m shell commands \r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mBoth bugs verified with\u001b[27Gcontrols.\u001b[37GNow\u001b[41Glet\u001b[45Gme\u001b[48Gwrite\u001b[54Gthe\u001b[58Gtwo\u001b[62GBUG\u001b[66Greports\u001b[74Gand\u001b[78Gthe\u001b[82GSUMMARY.\r\u001b[2B\u001b[38;2;78;186;101m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(BUG-map-as\u001b[20Gign-moves-heap-string.md)\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  \u001b[39mWrote\u001b[12G\u001b[1m92\u001b[15G\u001b[22mlines\u001b[21Gto\u001b[24G\u001b[1mBUG-map-assign-moves-heap-string.md\r\u001b[2C\u001b[1B\u001b[22m   \u001b[38;2;248;248;242m\u001b[2m  1 \u001b[22mPlease file this upstream at"]
