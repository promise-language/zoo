[0.016, "o", "\u001b[H\r\u001b[41C\u001b[29B                   \u001b[30;1H\u001b[28;3H"]
[0.110, "o", "\u001b]52;c;IA==\u0007"]
[0.017, "o", "\u001b[H\r\u001b[22C\u001b[24B\u001b[38;2;153;153;153m9\u001b[33G8\u001b[39m\u001b[30;1H\u001b[28;3H"]
[0.047, "o", "\u001b[H\r\u001b[2C\u001b[6B\u001b[48;2;38;79;120mOwnership semantics differ from the guide's description. Let\u001b[64Gme probe the actual rule for passing a \u001b[38;2;177;185;249mstring\u001b[39m local to a \u001b[49m\u001b[30;1H\u001b[28;3H"]
[0.059, "o", "\u001b]0;⠐ Build a mini-git version control tool in Promise\u0007"]
[0.107, "o", "\u001b[H\r\u001b[24B\u001b[38;2;215;119;87m✻\u001b[39m\u001b[30;1H\u001b[28;3H"]
[0.043, "o", "\u001b[H\r\u001b[2C\u001b[7B\u001b[48;2;38;79;120mplain-\u001b[38;2;177;185;249mstring\u001b[39m param.                                                                                                   \u001b[49m\u001b[30;1H\u001b[28;3H"]
[0.015, "o", "\u001b[H\r\u001b[8B\u001b[48;2;38;79;120m                                                                                                                        \u001b[49m\u001b[30;1H\u001b[28;3H"]
[0.035, "o", "\u001b[H\r\u001b[9B\u001b[48;2;38;79;120m  \u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m                                                                                                  \u001b[49m\u001b[30;1H\u001b[28;3H"]
[0.015, "o", "\u001b[H\r\u001b[10B\u001b[48;2;38;79;120m                                                                                                                        \u001b[49m\u001b[30;1H\u001b[28;3H"]
[0.017, "o", "\u001b[H\r\u001b[24B\u001b[38;2;215;119;87m✶\u001b[39m\u001b[30;1H\u001b[28;3H"]
[0.016, "o", "\u001b[H\r\u001b[2C\u001b[11B\u001b[48;2;38;79;120mContrary to the guide, a plain \u001b[38;2;177;185;249mstring\u001b[39m param \u001b[1mmoves\u001b[22m the argument. I need \u001b[38;2;177;185;249m&\u001b[39m to borrow. Let me confirm the borrow syntax. \u001b[49m\u001b[30;1H\u001b[28;3H"]
[0.033, "o", "\u001b[H\r\u001b[12B\u001b[48;2;38;79;120m                                                                                                                        \u001b[49m\u001b[30;1H\u001b[28;3H"]
[0.017, "o", "\u001b[H\r\u001b[13B\u001b[48;2;38;79;120m  \u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m                                                                                                  \u001b[49m\u001b[30;1H\u001b[28;3H"]
[0.016, "o", "\u001b[H\r\u001b[14B\u001b[48;2;38;79;120m                                                                                                                        \u001b[49m\u001b[30;1H\u001b[28;3H"]
[0.017, "o", "\u001b[H\r\u001b[2C\u001b[15B\u001b[48;2;38;79;120mThe guide is wrong: a plain \u001b[38;2;177;185;249mstring\u001b[39m param \u001b[1mmoves\u001b[22m the arg at the call site but is treated as a non-movable borrow inside \u001b[49m\u001b[30;1H\u001b[28;3H"]
