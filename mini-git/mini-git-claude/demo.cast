[0.059, "o", "\u001b[H\u001b[6G\u001b[K\r\u001b[7C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m6\u001b[10G\u001b[22m- `promise version 2026.1 (channel stable, commit 4bf7e22)`\r\u001b[7C\u001b[1B\u001b[2m7\u001b[10G\u001b[22m- macOS 26.5.1 (arm64), Darwin 25.5.0\r\u001b[7C\u001b[1B\u001b[2m8\u001b[10G\u001b[22m\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m9\u001b[10G\u001b[22m## Summary\u001b[39m\u001b[K\r\u001b[6C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m10\u001b[10G\u001b[22mMove analysis is not branch-sensitive for early returns. If a move-type variable\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153m… +58 lines \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mNow a clean representative\u001b[30Gsession\u001b[38Gfor\u001b[42Gthe\u001b[46Gsummary,\u001b[55Gthen\u001b[60GI'll\u001b[65Gwrite\u001b[71GSUMMARY.md.\r\u001b[2B\u001b[38;2;153;153;153m⏺\u001b[3G\u001b[39mRunning \u001b[1m1\u001b[22m shell command…\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  $ BIN=/Users/xxxxx/prog/zoo/mini-git/mini-git-claude/mini-git-claude\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153mrm -rf /tmp/demo && mkdir -p /tmp/demo && cd /tmp/demo\r\u001b[1B\u001b[39m     \u001b[38;2;153;153;153mset -x\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153m$BIN ini\u001b[15G\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153mprintf 'hello\\nworld\\n' > notes.txt\r"]
[0.000, "o", "\u001b[10C\u001b[1Badd notes.txt\r\u001b[5C\u001b[1B$BIN status\u001b[39m\u001b[K\r\u001b[10C\u001b[1B\u001b[38;2;153;153;153mcommit -m \"initial notes\"\r\u001b[5C\u001b[1Bprintf 'hello\\nworld\\nthird line\\n' > notes.txt\r\u001b[10C\u001b[1Badd not…\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(SUMMARY.md)\u001b[30;1H\u001b[28;3H"]
[0.019, "o", "\u001b[H\u001b[6G\u001b[38;2;153;153;153mrm -rf /tmp/demo && mkdir -p /tmp/demo && cd /tmp/demo\r\u001b[5C\u001b[1Bset -x\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153m$BIN init\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153mprintf 'hello\\nworld\\n' > notes.txt\r\u001b[5C\u001b[1B$BIN add notes.txt\r\u001b[5C\u001b[1B$BIN status\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153m$BIN commit\u001b[18G-m \"initial notes\"\r\u001b[5C\u001b[1Bprintf 'hello\\nworld\\nthird line\\n' > notes.txt\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153m$BIN add not…\u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;78;186;101m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(SUMMARY.md)\u001b[K\r\u001b[4C\u001b[1B\u001b[38;2;153;153;153m \u001b[39mWrote \u001b[1m103\u001b[22m lines to \u001b[1mSUMMARY.md\u001b[22m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m  1 \u001b[22m# mini-git — build summary\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m  2 \u001b[22m\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m  3 \u001b[22m## What I built\r\u001b[5C\u001b[1B\u001b[2m  4 \u001b[22mA self-contained \"mini-git\" in a single Promise source file (`main.pr`),\r\u001b[5C\u001b[1B\u001b[2m  5 \u001b[22mscaffolded with `promise init` and compiled to one binary with `promise build`.\r\u001b[5C\u001b[1B\u001b[2m  6 \u001b[22mIt implements all ten subcommand"]
[0.000, "o", "s: `init`, `add`, `rm`, `status`, `commit -m`,\r\u001b[5C\u001b[1B\u001b[2m  7 \u001b[22m`log`, `show`, `diff`, `checkout`, and `reset`.\r\u001b[5C\u001b[1B\u001b[2m  8 \u001b[22m\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m  9 \u001b[22mAll state lives on disk under `.minigit/`:\r\u001b[5C\u001b[1B\u001b[2m 10 \u001b[22m- `objects/<hash>` — raw file bytes, content-addressed with FNV-1a (64-bit, 16\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153m… +93 lines \u001b[39m\u001b[K\u001b[30;1H\u001b[28;3H"]
[0.037, "o", "\u001b[H\r\u001b[24B\u001b[38;2;215;119;87m✳\u001b[39m\u001b[30;1H\u001b[28;3H"]
[0.007, "o", "\u001b[H\u001b[6G\u001b[38;2;248;248;242m\u001b[2m  7 \u001b[22m- macOS 26.5.1 (arm64), Darwin 25.5.0\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m  8 \u001b[22m\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m  9 \u001b[22m## Summary\r\u001b[5C\u001b[1B\u001b[2m 10 \u001b[22mMove analysis is not branch-sensitive for early returns. If a move-type variable\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153m… +58 lines \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mNow a clean representative session\u001b[38Gfor\u001b[42Gthe\u001b[46Gsummary,\u001b[55Gthen\u001b[60GI'll\u001b[65Gwrite\u001b[71GSUMMARY.md.\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell\u001b[15Gc\u001b[17Gmmand \u001b[39m\u001b[30;1H\u001b[28;3H"]
