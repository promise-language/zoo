[0.160, "o", "\u001b[H\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mscan works on literals\u001b[26Gbut not on\u001b[37Gthe \u001b[42Gxecut\u001b[48G output. Let\u001b[61Gme narrow down\u001b[76Gwhat differs.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[39m Found it: \u001b[38;2;177;185;249mscan[int]\u001b[39m works on a string\u001b[41G\u001b[1mliteral\u001b[49G\u001b[22mbut\u001b[53Greturns\u001b[61G0\u001b[63Gon\u001b[66Ga\u001b[68Gstring\u001b[75G\u001b[1mvariable\u001b[22m.\u001b[85GThat's\u001b[92Ga\u001b[94Greal\u001b[99Gcompiler\u001b[108Gbug.\u001b[113GLet\u001b[117Gme\r\u001b[2C\u001b[1Bpin down the\u001b[16Gminimal\u001b[24Grepro\u001b[30Gand\u001b[34Gthe\u001b[38Gclosest-compiling\u001b[56Gcontrol.\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m shell commands \r\u001b[5C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mNow it's clear — the discriminator\u001b[38Gis\u001b[41G\u001b[1mstring interpolation\u001b[22m,\u001b[63Gnot\u001b[67Gliteral-vs-variable.\u001b[88G\u001b[38;2;177;185;249mscan[int]\u001b[98G\u001b[39minside\u001b[105G\u001b[38;2;177;185;249m\"{...}\"\u001b[113G\u001b[39mreturns\r\u001b[2C\u001b[1B0;\u001b[6Gassigned to a local firs"]
