[0.102, "o", "\u001b[H\r\u001b[2C\u001b[2BI have everything I\u001b[23Gneed.\u001b[29GLet me v\u001b[38Glidate\u001b[45Gth\u001b[48G trickiest primitives\u001b[70G(u64 wrapping multiply for FNV,\u001b[102Gbyte\u001b[107Ground-trip,\r\u001b[2C\u001b[1Bsort,\u001b[9G\u001b[38;2;177;185;249mas\u001b[12G\u001b[39mcast)\u001b[18Gin\u001b[21Ga\u001b[23Gscratch\u001b[31Gprogram\u001b[39Gbefore\u001b[46Gwriting\u001b[54Gthe\u001b[58Gfull\u001b[63Gtool.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mFNV-1a\u001b[10Gis\u001b[13Gcorrect\u001b[21G(\u001b[38;2;177;185;249ma430d84680aabd0b\u001b[39G\u001b[39mis\u001b[42Gthe\u001b[46Gknown\u001b[52GFNV-1a/64\u001b[62Gof\u001b[65G\"hello\").\u001b[75GNow\u001b[79Glet\u001b[83Gme\u001b[86Gtest\u001b[91Gfile\u001b[96Gbyte\u001b[101GI/O,\u001b[106G\u001b[38;2;177;185;249muse\u001b[110G\u001b[39mcleanup,\r\u001b[1B \u001b[3G\u001b[38;2;177;185;249mos.args\u001b[39m, and the \u001b[38;2;177;185;249mdate\u001b[39m timestamp.\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[5C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[38;2;177;185;249mpromise run -- args\u001b[39m isn't passing args\u001b[42Gas\u001b[45GI\u001b[47Gexpected.\u001b[57GLet\u001b[61Gme\u001b[64Gbuild\u001b[70Gand\u001b[74Grun\u001b[78Gthe\u001b[82Gbinary\u001b[89Gdirectly."]
