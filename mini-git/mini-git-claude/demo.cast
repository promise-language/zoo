[0.071, "o", "\u001b[H\u001b[6G\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mOwnership semantics differ\u001b[30Gfrom\u001b[35Gthe\u001b[39Gguide's\u001b[47Gdescription.\u001b[60GLet\u001b[64Gme\u001b[67Gprobe\u001b[73Gthe\u001b[77Gactual\u001b[84Grule\u001b[89Gfor\u001b[93Gpassing\u001b[101Ga\u001b[103G\u001b[38;2;177;185;249mstring\u001b[110G\u001b[39mlocal\u001b[116Gto\u001b[119Ga\r\u001b[2C\u001b[1Bplain-\u001b[38;2;177;185;249mstring\u001b[16G\u001b[39mparam.\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mContrary to the guide,\u001b[26Ga\u001b[28Gplain\u001b[34G\u001b[38;2;177;185;249mstring\u001b[41G\u001b[39mparam\u001b[47G\u001b[1mmoves\u001b[53G\u001b[22mthe\u001b[57Gargument.\u001b[67GI\u001b[69Gneed\u001b[74G\u001b[38;2;177;185;249m&\u001b[76G\u001b[39mto\u001b[79Gborrow.\u001b[87GLet\u001b[91Gme\u001b[94Gconfirm\u001b[102Gthe\u001b[106Gborrow\u001b[113Gsyntax.\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mThe guide is wrong: a\u001b[25Gplain\u001b[31G\u001b[38;2;177;185;249mstring\u001b[38G\u001b[39mparam\u001b[44G\u001b[1mmoves\u001b[50G\u001b[22mthe\u001b[54Garg\u001b[58Gat\u001b[61Gthe\u001b[65Gcall\u001b[70Gsite\u001b[75Gbut\u001b[79Gis\u001b[82Gtreated\u001b[90Gas\u001b[93Ga\u001b[9"]
[0.000, "o", "5Gnon-movable\u001b[107Gborrow\u001b[114Ginside\r\u001b[2C\u001b[1Bthe\u001b[7Gcallee.\u001b[15GThe\u001b[19Greal\u001b[24Gborrow\u001b[31Gform\u001b[36Gis\u001b[39G\u001b[38;2;177;185;249mstring& s\u001b[39m.\u001b[50GLet\u001b[54Gme\u001b[57Gverify\u001b[64Ga\u001b[66Gcouple\u001b[73Gof\u001b[76Gconsequences\u001b[89G(borrowing\u001b[100Ga\u001b[102Gtemporary/literal,\r\u001b[1B \u001b[3Gand\u001b[7Gre-use after a borrow) before rew\u001b[41Giting with consisten\u001b[62G borrow\u001b[70Gd\u001b[72Gscipline.\u001b[82G\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mAll confirmed, including\u001b[28Gthat\u001b[33Gborrowing\u001b[43Gtemporaries/literals\u001b[64Gworks.\u001b[71GNow\u001b[75GI'll\u001b[80Grewrite\u001b[88Gwith\u001b[93Gconsistent\u001b[104Gborrow\r\u001b[2C\u001b[1Bdiscipline:\u001b[15G\u001b[38;2;177;185;249mstring&\u001b[23G\u001b[39mfor\u001b[27Gread-only\u001b[37Gparams,\u001b[45Gthin\u001b[50Gwrappers\u001b[59Gcentralizing\u001b[72Gthe\u001b[76G\u001b[38;2;177;185;249m.clone()\u001b[85G\u001b[39mneeded\u001b[92Gby\u001b[95Gconsuming\u001b[105Gstdlib\u001b[112Gcalls.\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(main.pr)\u001b[K\u001b[30;1H\u001b[28;3H"]
