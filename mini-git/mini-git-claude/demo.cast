[0.083, "o", "\u001b[H\r\u001b[5C\u001b[1B\u001b[38;2;220;90;90m\u001b[48;2;61;1;0m 227 -\u001b[38;2;248;248;242m  save_index(idx);                                                                                    \r\u001b[1B\u001b[49m\u001b[39m \u001b[3G   \u001b[38;2;220;90;90m\u001b[48;2;61;1;0m 228 -\u001b[38;2;248;248;242m  print_line(\"added {file}  ({h})\");                                                                  \r\u001b[1B\u001b[49m\u001b[39m     \u001b[38;2;80;200;80m\u001b[48;2;2;40;0m 226 +\u001b[38;2;248;248;242m  idx[file] = h.clone();                  // clone: a map-inserted heap string is                     \r\u001b[5C\u001b[1B\u001b[38;2;80;200;80m 227 +\u001b[38;2;248;248;242m  save_index(idx);                        // consumed but not flagged, so reusing                     \r\u001b[5C\u001b[1B\u001b[38;2;80;200;80m 228 +\u001b[38;2;248;248;242m  print_line(\"added {file}  ({h})\");\u001b[48;2;4;71;0m      // `h` after save_index would read empty\u001b[48;2;2;40;0m                    \r\u001b[5C\u001b[1B\u001b[38;2;80;200;80m 229 +\u001b[38;2;248;248;242m                                          // (see BUG-map-assign-moves-heap-string)                   \r\u001b[5C\u001b[1"]
[0.000, "o", "B\u001b[49m\u001b[2m 230 \u001b[22m }\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 231 \u001b[22m \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 232 \u001b[22m cmd_rm!(string file) {\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mFixed. Now a thorough end-to-end test of every command, including a binary round-trip and all three diff cases.\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m⏺\u001b[3G\u001b[39mRunning \u001b[1m1\u001b[13G\u001b[22mshell\u001b[19Gcommand…\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  $ BIN=/Users/xxxxx/prog/zoo/mini-git/mini-git-claude/mini-git-claude\r\u001b[5C\u001b[1Brm -rf /tmp/mg && mkdir -p /tmp/mg && cd /tmp/mg\r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;153;153;153m$BIN init >/dev/null\r\u001b[5C\u001b[1Bprintf 'hello\\nworld\\n' > a.txt\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153mprintf 'first\\n' > b.txt\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153m$BIN add a.txt >/dev/null; $BIN add b.txt >/dev/null\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153mC1=$($BIN commit -m \"c1: a + b\" | awk '{print $2}'…\u001b[39m\u001b[30;1H\u001b[28;3H"]
