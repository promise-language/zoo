[0.000, "o", "\u001b[3G\u001b[3mafter\u001b[23m. That smells like a move bug. Let me minimize it.\u001b[K\r\u001b[2B\u001b[38;2;153;153;153m \u001b[3G\u001b[39mRunning \u001b[1m1\u001b[22m shell command…\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  $ cd /tmp && cat > mv.pr <<'EOF'\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153mmain() {\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153mmap[string, string] m = {:};\r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;153;153;153mstring h\u001b[15G= \"abc\u001b[22Gef\";\r\u001b[5C\u001b[1Bprint_line(\"before = {h}\");\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153mm[\"k\"] = h;\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;2;153;153;153mprint_line(\"after = {h}\");\u001b[33G\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;2;153;153;153m}\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153mEOF\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153mpromise build mv.pr 2>&1 && ./mv\u001b[39m\u001b[30;1H\u001b[28;3H"]
