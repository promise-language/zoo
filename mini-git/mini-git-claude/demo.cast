[0.012, "o", "\u001b[H\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mWorks fine. The d\u001b[21Gfference must be the real \u001b[38;2;177;185;249mfnv1a_hex\u001b[39m/\u001b[38;2;177;185;249mto_hex16\u001b[39m (l\u001b[69Gop-built\u001b[78Gstring)\u001b[86Gor \u001b[38;2;177;185;249mread_bytes\u001b[39m. Let me reproduce\u001b[K\r\u001b[2C\u001b[1Bw\u001b[5Gth the\u001b[12Gactual funct\u001b[25Gons.\u001b[30G\u001b[K\r\u001b[2C\u001b[4BReproduced. The differenc\u001b[29G: \u001b[38;2;177;185;249mmv2\u001b[35G\u001b[39mreturned a \u001b[1mliteral\u001b[22m string; \u001b[38;2;177;185;249mmv3\u001b[39m builds th\u001b[76G hash in a loop (a heap\u001b[100Gstrin\u001b[106G). A h\u001b[114Gp\u001b[K\r\u001b[2C\u001b[1B(non-literal) string assigned via \u001b[38;2;177;185;249midx[file] = h\u001b[51G\u001b[39mthen read again comes\u001b[73Gback\u001b[78Gempty\u001b[84G—\u001b[86Gwhile\u001b[92Ga\u001b[94Gliteral\u001b[102Gsurvives.\u001b[112GLet\u001b[116Gme\r\u001b[2C\u001b[1Bpin\u001b[7Gdown\u001b[12Gthe\u001b[16Gexact\u001b[22Gtrigger\u001b[30Gwith\u001b[35Gcontrols.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mMinimal map-assign\u001b[22Gis fine — so the trigger is more specific\u001b[72Gbisect from the failing \u001b[38;2;177;185;249mmv3\u001b[100G\u001b[39mby toggling "]
[0.000, "o", "each\u001b[K\r\u001b[2C\u001b[1Bs\u001b[6Gpect (the \u001b[38;2;177;185;249msink(idx)\u001b[39m call, the param key, the failable context).\u001b[K\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mClear signal: the trigger is \u001b[1mpassing the map to another function after the heap-string insert\u001b[97G\u001b[22m(A/B/D\u001b[104Gfail;\u001b[110GC,\u001b[113Gwith\u001b[118Gno\r\u001b[2C\u001b[1Bsuch call, works). Failable-ness and key kind are irrelevant. Let me confirm it's the\u001b[89Gmap-borrow\u001b[100Gspecifically\u001b[113G(not\r\u001b[2C\u001b[1Bjust any intervening\u001b[24Gcall)\u001b[30Gand\u001b[34Gcheck\u001b[40Gwhether\u001b[48Gthe\u001b[52Gmap's\u001b[58Gstored\u001b[65Gvalue\u001b[71Galso\u001b[76Gcorrupts.\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[9G\u001b[22mshell command \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[6G\u001b[39m\u001b[K\u001b[30;1H\u001b[28;3H"]
