[0.117, "o", "\u001b[H\r\u001b[1B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mThe blob hashes are correct\u001b[31Gon\u001b[34Gdisk\u001b[39G(\u001b[38;2;177;185;249m2925835410388969\u001b[39m,\u001b[58G\u001b[38;2;177;185;249m15d0dddb989be669\u001b[39m)\u001b[76Gand\u001b[80Grecorded\u001b[89Gin\u001b[92Gthe\u001b[96Gcommit\u001b[103G—\u001b[105Gbut\u001b[109Gthe\u001b[113G\u001b[38;2;177;185;249m{h}\u001b[117G\u001b[39min\r\u001b[2C\u001b[1B\u001b[38;2;177;185;249madd\u001b[39m's\u001b[9Gsuccess\u001b[17Gmessage\u001b[25Gprinted\u001b[33Gempty.\u001b[40G\u001b[38;2;177;185;249mh\u001b[42G\u001b[39mis\u001b[45Gused\u001b[50Gfine\u001b[55Gin\u001b[58Gthe\u001b[62Gpath\u001b[67Ginterpolation\u001b[81G\u001b[3mbefore\u001b[88G\u001b[23m\u001b[38;2;177;185;249midx[file] = h\u001b[39m,\u001b[103Gthen\u001b[108Gprints\u001b[115Gempty\r\u001b[1B \u001b[3G\u001b[3mafter\u001b[23m. That\u001b[15Gsm\u001b[18Glls lik\u001b[26G a move bug. L\u001b[41Gt me minimize it.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[39m Minimal map-assign is fine. The bug must\u001b[44Gbe\u001b[47Gmore\u001b[52Gspecific\u001b[61Gto\u001b[64G\u001b[38;2;177;185;249madd\u001b[39m's\u001b[70Gshape.\u001b[77GLet\u001b[81Gme\u001b[84Greproduce\u001b[94Gits\u001b[98Gexact\u001b[104Gpattern.\r"]
[0.000, "o", "\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell comman\u001b[22G \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[38;2;177;185;249mgo\u001b[6G\u001b[39mis a reserved keyword.\u001b[29GLet\u001b[33Gme\u001b[36Grename\u001b[43Gand\u001b[47Gretry.\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m s\u001b[11Gell commands \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mWorks fine. The difference\u001b[30Gmust\u001b[35Gbe\u001b[38Gthe\u001b[42Greal\u001b[47G\u001b[38;2;177;185;249mfnv1a_hex\u001b[39m/\u001b[38;2;177;185;249mto_hex16\u001b[66G\u001b[39m(loop-built\u001b[78Gstring)\u001b[86Gor\u001b[89G\u001b[38;2;177;185;249mread_bytes\u001b[39m.\u001b[101GLet\u001b[105Gme\u001b[108Greproduce\r\u001b[2C\u001b[1Bwith\u001b[8Gthe\u001b[12Gactual\u001b[19Gfunctions.\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[6G\u001b[39m\u001b[K\r\u001b[33C\u001b[2B\u001b[38;2;153;153;153m9\u001b[46Gthought for 8s)\u001b[39m\u001b[30;1H\u001b[28;3H"]
