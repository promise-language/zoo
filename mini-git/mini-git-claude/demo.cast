[0.104, "o", "\u001b[H\u001b[6G\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mNow change the unnecessary mutable-borrow params to shared borrows (fixes the\u001b[81Gdouble-borrow\u001b[95Gin\u001b[98G\u001b[38;2;177;185;249mdiff\u001b[103G\u001b[39mand\u001b[107Gis\u001b[110Gmore\r\u001b[2C\u001b[1Bcorrect):\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m2\u001b[22m shell commands \r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mCompiles. Now let me exercise\u001b[33Gthe\u001b[37Gfull\u001b[42Gworkflow\u001b[51Gend-to-end\u001b[62Gin\u001b[65Ga\u001b[67Gscratch\u001b[75Gdirectory.\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mListed \u001b[1m1\u001b[22m directory, ran \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[38;2;177;185;249mcommit\u001b[39m works, but \u001b[38;2;177;185;249madd\u001b[39m printed an \u001b[1mempty hash\u001b[47G\u001b[22m\u001b[38;2;177;185;249m()\u001b[39m.\u001b[51GLet\u001b[55Gme\u001b[58Ginspect\u001b[66Gwhat\u001b[71Gactually\u001b[80Ggot\u001b[84Ghashed/written.\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mThe blob hashes are correct\u001b[31Gon\u001b[34Gdisk\u001b[39G(\u001b[38;2;177;185;249m2925835410388969\u001b[39m,\u001b[58G\u001b[38;2;177;185;249m15d0dddb989be669\u001b[39m)\u001b[76Gand\u001b"]
[0.000, "o", "[80Grecorded\u001b[89Gin\u001b[92Gthe\u001b[96Gcommit\u001b[103G—\u001b[105Gbut\u001b[109Gthe\u001b[113G\u001b[38;2;177;185;249m{h}\u001b[117G\u001b[39min\r\u001b[2C\u001b[1B\u001b[38;2;177;185;249madd\u001b[39m's\u001b[9Gsuccess\u001b[17Gmessage\u001b[25Gprinted\u001b[33Gempty.\u001b[40G\u001b[38;2;177;185;249mh\u001b[42G\u001b[39mis\u001b[45Gused\u001b[50Gfine\u001b[55Gin\u001b[58Gthe\u001b[62Gpath\u001b[67Ginterpolation\u001b[81G\u001b[3mbefore\u001b[88G\u001b[23m\u001b[38;2;177;185;249midx[file] = h\u001b[39m,\u001b[103Gthen\u001b[108Gprints\u001b[115Gempty\r\u001b[1B \u001b[3G\u001b[3mafter\u001b[23m. That smells like a move\u001b[34Gbug.\u001b[39GLet me minimize it.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mMinimal map-assign is\u001b[25Gfine.\u001b[31GThe\u001b[35Gbug\u001b[39Gmust\u001b[44Gbe\u001b[47Gmore\u001b[52Gspecific\u001b[61Gto\u001b[64G\u001b[38;2;177;185;249madd\u001b[39m's\u001b[70Gshape.\u001b[77GLet\u001b[81Gme\u001b[84Greproduce\u001b[94Gits\u001b[98Gexact\u001b[104Gpattern.\r\u001b[2B\u001b[38;2;153;153;153m⏺\u001b[3G\u001b[39mRunning\u001b[11G\u001b[1m1\u001b[13G\u001b[22mshell\u001b[19Gcommand…\r\u001b[22C\u001b[2B\u001b[38;2;153;153;153m1\u001b[39m\u001b[30;1H\u001b[28;3H"]
