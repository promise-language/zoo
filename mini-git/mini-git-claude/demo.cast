[0.188, "o", "\u001b[H\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mNow checkout and reset,\u001b[27Gverifying\u001b[37Gactual\u001b[44Gfile\u001b[49Gcontents\u001b[58Gon\u001b[61Gdisk:\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mAll semantics correct.\u001b[26GLet\u001b[30Gme\u001b[33Gverify\u001b[40Gbinary-safety\u001b[54G(the\u001b[59Gblob\u001b[64Gstore\u001b[70Gmust\u001b[75Ground-trip\u001b[86Garbitrary\u001b[96Gbytes)\u001b[103Gand\u001b[107Gdeterminism\u001b[119Gof\r\u001b[2C\u001b[1Bblob\u001b[8Ghashing:\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mBinary round-trips byte-for-byte\u001b[36Gand\u001b[40Gblobs\u001b[46Gare\u001b[50Gcorrectly\u001b[60Gcontent-addressed.\u001b[79GEverything\u001b[90Gworks.\u001b[97GLet\u001b[101Gme\u001b[104Gtighten\u001b[112Gthe\u001b[116Gscope\r\u001b[2C\u001b[1Bof\u001b[6GBug\u001b[10G#1\u001b[13G—\u001b[15Gdoes\u001b[20Git\u001b[23Ghappen\u001b[30Gfor\u001b[34Ga\u001b[36Gbare\u001b[41Gfailable\u001b[50Gcall\u001b[55Gas\u001b[58Ga\u001b[60Gdirect\u001b[67Gfunction\u001b[76Gargument,\u001b[86Gor\u001b[89Gonly\u001b[94Ginside\u001b[101Gstring\r\u001b[1B \u001b[3Ginte\u001b[8Gpolation?\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;"]
