[0.055, "o", "\u001b[H\u001b[6G\u001b[K\r\u001b[7C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m30\u001b[12G\u001b[22m}\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 231 \u001b[22m \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m 232 \u001b[22m cmd_rm!(string file) {\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mFixed. Now a thorough end-to-end test of every command, including a binary round-trip and all three diff cases.\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[5C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mAll correct. Now checkout vs reset\u001b[38Gsemantics,\u001b[49Gbinary\u001b[56Ground-trip,\u001b[68Gdeterminism\u001b[80Gof\u001b[83Gcommit\u001b[90Gids,\u001b[95Gand\u001b[99Gthe\u001b[103Gremaining\u001b[113Gerror\r\u001b[2C\u001b[1Bcases.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m \u001b[3G\u001b[39mRunning\u001b[11G\u001b[1m1\u001b[13G\u001b[22mshell\u001b[19Gcommand…\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  $ BIN=/Users/xxxxx/prog/zoo/mini-git/mini-git-claude/mini-git-claude\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153mcd /tmp/mg\r\u001b[2C\u001b[1B\u001b[39m   \u001b[38;2;153;153;153mC1=c7c497965094209e\r\u001b[5C\u001b[1Be"]
[0.000, "o", "cho \"=== before checkout: a.txt has 3 lines, c.txt exists ===\"\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153mwc -l < a.txt; ls c.txt\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;2;153;153;153mecho \"=== checkout C1 (a.txt -> 2 lines; c.txt left on disk since C1 didn't track it) ===\"\r\u001b[5C\u001b[1B$BIN checkout \"$C1\"\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;2;153;153;153m…\u001b[39m\u001b[K\u001b[30;1H\u001b[28;3H"]
