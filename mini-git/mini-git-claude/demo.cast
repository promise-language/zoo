[0.107, "o", "\u001b[H\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mFixed. Now a thorough\u001b[25Gend-to-end\u001b[36Gtest\u001b[41Gof\u001b[44Gevery\u001b[50Gcommand,\u001b[59Gincluding\u001b[69Ga\u001b[71Gbinary\u001b[78Ground-trip\u001b[89Gand\u001b[93Gall\u001b[97Gthree\u001b[103Gdiff\u001b[108Gcases.\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mAll correct. Now checkout\u001b[29Gvs\u001b[32Greset\u001b[38Gsemantics,\u001b[49Gbinary\u001b[56Ground-trip,\u001b[68Gdeterminism\u001b[80Gof\u001b[83Gcommit\u001b[90Gids,\u001b[95Gand\u001b[99Gthe\u001b[103Gremaining\u001b[113Gerror\r\u001b[2C\u001b[1Bcases.\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mcheckout restores files\u001b[27G+\u001b[29Gmoves\u001b[35GHEAD;\u001b[41Greset\u001b[47Gmoves\u001b[53GHEAD\u001b[58Gonly.\u001b[64GNow\u001b[68Gthe\u001b[72Gbinary\u001b[79Ground-trip\u001b[90Gand\u001b[94Gremaining\u001b[104Gerror/edge\u001b[115Gcases:\r\u001b[2B \u001b[3G\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mEverything passes: byte-exact\u001b[33Gbinary\u001b[40Ground-trip,\u001b[52Gall\u001b[56Gerror\u001b[62Gcases\u001b[68Gclean\u001b[74Gwith\u001b[79Gexit\u001b[84G1.\u001b[87GNow\u001b[91Glet\u001b[95Gme\u001b[98G"]
