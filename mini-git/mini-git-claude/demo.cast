[0.112, "o", "\u001b[H\r\u001b[1B \u001b[3Ginte\u001b[8Gpolation?\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mNow the bug is precisely\u001b[28Gscoped:\u001b[36Git\u001b[39Gonly\u001b[44Gaffects\u001b[52G\u001b[1mstring interpolation\u001b[22m,\u001b[74Gnot\u001b[78Gplain\u001b[84Gargument\u001b[93Gpositions.\u001b[104GLet\u001b[108Gme\u001b[111Gwrite\u001b[117Gthe\r\u001b[2C\u001b[1Bdeliverables.\u001b[17GFirst,\u001b[24Gthe\u001b[28Gtwo\u001b[32GBUG\u001b[36Gfiles:\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;78;186;101m⏺\u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(BUG-bare-failable-call-in-interpolation.md)\r\u001b[1B\u001b[38;2;153;153;153m  ⎿  \u001b[39mWrote\u001b[12G\u001b[1m95\u001b[15G\u001b[22mlines\u001b[21Gto\u001b[24G\u001b[1mBUG-bare-failable-call-in-interpolation.md\r\u001b[1B\u001b[22m \u001b[3G   \u001b[38;2;248;248;242m\u001b[2m  1 \u001b[22mPlease file this upstream at https://github.com/promise-language/promise/issues\r\u001b[1B\u001b[39m     \u001b[38;2;248;248;242m\u001b[2m  2 \u001b[22m\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;2;248;248;242m\u001b[2m3\u001b[10G\u001b[22m# B\u001b[14Gr\u001b[17Gauto-propagating failable call \u001b[49Gnside string \u001b[63Gnterpolation yields the zero value (and stack-overf\r\u001b[7C\u001b[1B\u001b[2m \u001b[10G\u001b[22mlows for `string`)\r\u001b[7C\u001b[1B\u001b[2m4\u001b[10G\u001b["]
