[0.038, "o", "\u001b[H\u001b[3G(non-literal)\u001b[17Gstring\u001b[24Gassigned\u001b[33Gvia\u001b[37G\u001b[38;2;177;185;249midx[file] = h\u001b[51G\u001b[39mthen\u001b[56Gread\u001b[61Gagain\u001b[67Gcomes\u001b[73Gback\u001b[78Gempty\u001b[84G—\u001b[86Gwhile\u001b[92Ga\u001b[94Gliteral\u001b[102Gsurvives.\u001b[112GLet\u001b[116Gme\r\u001b[1B \u001b[3Gp\u001b[6G down the exact\u001b[22Gtrigger\u001b[30Gwith\u001b[35Gcontrols.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[2C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mMinimal\u001b[11Gmap-assign\u001b[22Gis\u001b[25Gfine\u001b[30G—\u001b[32Gso\u001b[35Gthe\u001b[39Gtrigger\u001b[47Gis\u001b[50Gmore\u001b[55Gspecific.\u001b[65GLet\u001b[69Gme\u001b[72Gbisect\u001b[79Gfrom\u001b[84Gthe\u001b[88Gfailing\u001b[96G\u001b[38;2;177;185;249mmv3\u001b[100G\u001b[39mby\u001b[103Gtoggling\u001b[112Geach\r\u001b[1B \u001b[3Gsuspect (the \u001b[38;2;177;185;249msink(idx)\u001b[39m call,\u001b[32Gthe param key, the failable context).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[24G\u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mClear signal: the trigger\u001b[29Gis\u001b[32G\u001b[1mpassing the map to another function after the heap-string insert\u001b[97G\u001b[22m(A/B/D\u001b[104Gfail;\u001b[110GC,\u001b[113Gwith\u001b[118Gno\r\u001b[2C\u001b[1Bs"]
[0.000, "o", "uch\u001b[8Gcall,\u001b[14Gworks).\u001b[22GFailable-ness\u001b[36Gand\u001b[40Gkey\u001b[44Gkind\u001b[49Gare\u001b[53Girrelevant.\u001b[65GLet\u001b[69Gme\u001b[72Gconfirm\u001b[80Git's\u001b[85Gthe\u001b[89Gmap-borrow\u001b[100Gspecifically\u001b[113G(not\r\u001b[1B \u001b[3Gjust any interveni\u001b[22Gg call) and check whether the map's stored value also corrupts.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m⏺\u001b[3G\u001b[39mThe trigger is pinned: \u001b[38;2;177;185;249m\u001b[1mmap[key] = heapString\u001b[39m followed by passing the map to a function corrupts the source variable\r\u001b[1B\u001b[22m  (the map insert moves the heap string without\u001b[49Gflagging\u001b[58Git;\u001b[62Gthe\u001b[66Glater\u001b[72Gread\u001b[77Gis\u001b[80Ga\u001b[82Gsilent\u001b[89Guse-after-move).\u001b[106GLet\u001b[110Gme\u001b[113Glock\u001b[118Gin\r\u001b[2C\u001b[1Ba\u001b[5Gclean deterministic repro, then fix the real code.\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153mRan \u001b[1m1\u001b[22m shell command \r\u001b[5C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;2;255;255;255m⏺\u001b[6G\u001b[39m\u001b[K\u001b[30;1H\u001b[28;3H"]
