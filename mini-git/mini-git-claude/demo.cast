[0.024, "o", "\u001b[H\r\u001b[1B\u001b[38;2;215;119;87m╭───\u001b[6GClaude Code\u001b[18G\u001b[38;2;153;153;153mv2.1.185\u001b[27G\u001b[38;2;215;119;87m─────────────────────────────────────────────────────────────────────────────────────────────╮\r\u001b[1B│\u001b[54G\u001b[2m│\u001b[56G\u001b[22m\u001b[1mWhat's new\u001b[120G\u001b[22m│\r\u001b[1B│\u001b[18G\u001b[39m\u001b[1mWelcome back George!\u001b[54G\u001b[22m\u001b[2m\u001b[38;2;215;119;87m│\u001b[56G\u001b[39m\u001b[22mAdded\u001b[62G`sandbox.credentials`\u001b[84Gsetting\u001b[92Gto\u001b[95Gblock\u001b[101Gsandboxed\u001b[111Gcommand…\u001b[120G\u001b[38;2;215;119;87m│\r\u001b[1B│\u001b[54G\u001b[2m│\u001b[56G\u001b[39m\u001b[22mAdded\u001b[62Gorg-configured\u001b[77Gmodel\u001b[83Grestrictions\u001b[96Gto\u001b[99Gthe\u001b[103Gmodel\u001b[109Gpicker,\u001b[117G`…\u001b[120G\u001b[38;2;215;119;87m│\r\u001b[1B│\u001b[24G▗\u001b[48;2;215;119;87m\u001b[38;2;0;0;0m ▗   ▖ \u001b[49m\u001b[38;2;215;119;87m▖\u001b[54G\u001b[2m│\u001b[56G\u001b[39m\u001b[22mAdded\u001b[62Gmouse\u001b[68Gclick\u001b[74Gsupport\u001b[82Gto\u001b[85Gselect\u001b[92Gmenus\u001b[98G(permission\u001b[110Gprompt"]
[0.000, "o", "s,…\u001b[120G\u001b[38;2;215;119;87m│\r\u001b[1B│\u001b[25G\u001b[39m\u001b[48;2;215;119;87m       \u001b[54G\u001b[49m\u001b[2m\u001b[38;2;215;119;87m│\u001b[56G\u001b[22m\u001b[38;2;153;153;153m\u001b[3m/release-notes for more\u001b[120G\u001b[23m\u001b[38;2;215;119;87m│\r\u001b[1B│\u001b[26G▘▘ ▝▝\u001b[54G\u001b[2m│\u001b[120G\u001b[22m│\r\u001b[1B│\u001b[8G\u001b[38;2;153;153;153mOpus 4.8 (1M context) · Claude Max · \u001b[54G\u001b[2m\u001b[38;2;215;119;87m│\u001b[120G\u001b[22m│\r\u001b[1B│\u001b[8G\u001b[38;2;153;153;xxxxxxxxxxxxxxxxxxx@gmail.com's Organization\u001b[54G\u001b[2m\u001b[38;2;215;119;87m│\u001b[120G\u001b[22m│\r\u001b[1B│\u001b[10G\u001b[38;2;153;153;153m~/prog/zoo/mini-git/mini-git-claude\u001b[54G\u001b[2m\u001b[38;2;215;119;87m│\u001b[120G\u001b[22m│\r\u001b[1B╰──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────╯\r\u001b[103C\u001b[14B\u001b[38;2;153;153;153m● high · /effort\r\u001b[1B\u001b[38;2;136;136"]
[0.000, "o", ";136m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1B\u001b[39m❯ \u001b[7mT\u001b[27m\u001b[2mry \"fix typecheck errors\"\r\u001b[1B\u001b[22m\u001b[38;2;136;136;136m────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[2C\u001b[1B\u001b[38;2;175;135;255m⏵⏵ accept edits on\u001b[38;2;153;153;153m (shift+tab to cycle) · ← for agents\u001b[39m\u001b[30;1H\u001b[28;3H"]
